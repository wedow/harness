#!/usr/bin/env python3
"""web_fetch — example tool plugin in Python.
Demonstrates that tools can be written in any language.
Drop into .harness/tools/ to enable."""

import json
import sys
import urllib.request

SCHEMA = {
    "name": "web_fetch",
    "description": "Fetch the contents of a URL and return the text. Useful for reading documentation, APIs, or web pages.",
    "input_schema": {
        "type": "object",
        "properties": {
            "url": {
                "type": "string",
                "description": "The URL to fetch"
            }
        },
        "required": ["url"]
    }
}

def main():
    if len(sys.argv) < 2:
        print("usage: web_fetch --schema | --describe | --exec", file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "--schema":
        json.dump(SCHEMA, sys.stdout)
    elif cmd == "--describe":
        print("Fetch URL contents")
    elif cmd == "--exec":
        data = json.load(sys.stdin)
        url = data["url"]
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "harness/0.1"})
            with urllib.request.urlopen(req, timeout=30) as resp:
                body = resp.read().decode("utf-8", errors="replace")
                # Truncate to avoid blowing up context
                if len(body) > 50000:
                    body = body[:50000] + "\n\n[truncated at 50000 chars]"
                print(body)
        except Exception as e:
            print(f"error fetching {url}: {e}")
            sys.exit(1)
    else:
        print(f"unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
