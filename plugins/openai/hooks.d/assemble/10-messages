#!/usr/bin/env bash
# 10-messages — read canonical session files, produce OpenAI messages array.
# Pipeline hook: receives partial payload on stdin, adds "messages" field.
set -euo pipefail

payload="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"

[[ -d "${msg_dir}" ]] || { echo "${payload}"; exit 0; }

messages="[]"

add_msg() {
  messages="$(printf '%s\n%s' "${messages}" "$1" | jq -s '.[0] + [.[1]]')"
}

for f in $(ls -1 "${msg_dir}"/*.md 2>/dev/null | sort); do
  _role=""
  _call_id=""
  _error="false"
  in_fm=false
  fm_done=false
  body=""
  while IFS= read -r line; do
    if [[ "${line}" == "---" ]] && ! ${fm_done}; then
      if ${in_fm}; then in_fm=false; fm_done=true; continue
      else in_fm=true; continue; fi
    fi
    if ${in_fm}; then
      case "${line}" in
        role:*)     _role="${line#role: }" ;;
        call_id:*)  _call_id="${line#call_id: }" ;;
        error:*)    _error="${line#error: }" ;;
      esac
    else
      body+="${line}"$'\n'
    fi
  done < "${f}"
  body="${body%$'\n'}"

  case "${_role}" in
    user)
      add_msg "$(printf '%s' "${body}" | jq -Rs '{role: "user", content: .}')"
      ;;
    assistant)
      # Parse text and tool_call blocks
      text_content=""
      tool_calls="[]"
      in_tool_block=false
      tool_id="" tool_name="" tool_body=""

      while IFS= read -r line; do
        if [[ "${line}" =~ ^\`\`\`tool_call\ id=([^ ]+)\ name=([^ ]+) ]]; then
          in_tool_block=true
          tool_id="${BASH_REMATCH[1]}"
          tool_name="${BASH_REMATCH[2]}"
          tool_body=""
          continue
        fi
        if ${in_tool_block} && [[ "${line}" == '```' ]]; then
          in_tool_block=false
          tool_calls="$(printf '%s\n%s' "${tool_calls}" "$(printf '%s' "${tool_body}" | jq -Rs '.')" \
            | jq -s --arg id "${tool_id}" --arg name "${tool_name}" \
            '.[0] + [{id: $id, type: "function", function: {name: $name, arguments: .[1]}}]')"
          continue
        fi
        if ${in_tool_block}; then
          tool_body+="${line}"
        else
          text_content+="${line}"$'\n'
        fi
      done <<< "${body}"
      text_content="${text_content%$'\n'}"

      # Build assistant message — OpenAI format uses tool_calls array, not content blocks
      tc_count="$(echo "${tool_calls}" | jq 'length')"
      if (( tc_count > 0 )); then
        if [[ -n "${text_content}" ]]; then
          add_msg "$(printf '%s\n%s' "$(printf '%s' "${text_content}" | jq -Rs '.')" "${tool_calls}" \
            | jq -s '{role: "assistant", content: .[0], tool_calls: .[1]}')"
        else
          add_msg "$(echo "${tool_calls}" | jq '{role: "assistant", tool_calls: .}')"
        fi
      else
        add_msg "$(printf '%s' "${text_content}" | jq -Rs '{role: "assistant", content: .}')"
      fi
      ;;
    tool_result)
      # OpenAI uses role: "tool" with tool_call_id
      add_msg "$(printf '%s' "${body}" | jq -Rs --arg id "${_call_id}" \
        '{role: "tool", tool_call_id: $id, content: .}')"
      ;;
  esac
done

printf '%s\n%s' "${payload}" "${messages}" | jq -c -s '.[0] + {messages: .[1]}'
