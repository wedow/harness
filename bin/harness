#!/usr/bin/env bash
# harness — minimal agent loop. everything else is plugins.
set -euo pipefail

HARNESS_VERSION="0.1.0"
readonly HARNESS_ROOT="${HARNESS_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
# Overridable
HARNESS_HOME="${HARNESS_HOME:-${HOME}/.harness}"
# Session store: nearest .harness/sessions/ walking up from CWD
if [[ -z "${HARNESS_SESSIONS:-}" ]]; then
  HARNESS_SESSIONS="${HARNESS_HOME}/sessions"
  _cur="${PWD}"
  while [[ "${_cur}" != "/" ]]; do
    [[ -d "${_cur}/.harness/sessions" ]] && { HARNESS_SESSIONS="${_cur}/.harness/sessions"; break; }
    _cur="$(dirname "${_cur}")"
  done; unset _cur
fi
HARNESS_MODEL="${HARNESS_MODEL:-}"
HARNESS_PROVIDER="${HARNESS_PROVIDER:-}"
HARNESS_MAX_TURNS="${HARNESS_MAX_TURNS:-100}"
HARNESS_LOG="${HARNESS_LOG:-/dev/stderr}"

# Export early — hooks run as subprocesses and need these
export HARNESS_VERSION HARNESS_ROOT HARNESS_HOME HARNESS_SESSIONS HARNESS_MODEL HARNESS_PROVIDER HARNESS_MAX_TURNS HARNESS_LOG

# --------------------------------------------------------------------------- #
#  Source discovery                                                            #
# --------------------------------------------------------------------------- #

_HARNESS_SOURCES=()

# Bootstrap with bundled plugins + HARNESS_HOME, then run hookable sources stage.
_refresh_sources() {
  _HARNESS_SOURCES=()
  local d
  for d in "${HARNESS_ROOT}/plugins"/*/; do
    [[ -d "${d}" ]] && _HARNESS_SOURCES+=("${d%/}")
  done
  [[ -d "${HARNESS_HOME}" ]] && _HARNESS_SOURCES+=("${HARNESS_HOME}")
  local result
  result="$(echo '{}' | call sources)" || return
  mapfile -t _HARNESS_SOURCES < <(echo "${result}" | jq -r '.sources[]')
  local IFS=':'; export HARNESS_SOURCES="${_HARNESS_SOURCES[*]}"
}

# --------------------------------------------------------------------------- #
#  Hook runner                                                                 #
# --------------------------------------------------------------------------- #
# Hooks are executables in hooks.d/<stage>/ directories. They are collected
# from all sources (local overrides global by basename), sorted by numeric
# prefix, and run as a pipeline: each hook's stdout feeds the next hook's
# stdin. Non-zero exit aborts the chain.

call() {
  local stage="$1"; shift

  # Collect hooks: last source wins per basename (local overrides global)
  declare -A hook_map=()
  local src f
  for src in "${_HARNESS_SOURCES[@]}"; do
    [[ -d "${src}/hooks.d/${stage}" ]] || continue
    for f in "${src}/hooks.d/${stage}"/*; do
      [[ -x "${f}" ]] && hook_map["$(basename "${f}")"]="${f}"
    done
  done

  local current=""; [[ ! -t 0 ]] && current="$(cat)"
  (( ${#hook_map[@]} )) || { printf '%s' "${current}"; return 0; }

  export HARNESS_SESSION="${SESSION_DIR:-}" HARNESS_STAGE="${stage}"

  # Sort by basename (numeric prefix gives order), execute as pipeline
  local base
  while IFS= read -r base; do
    current="$(echo "${current}" | "${hook_map[$base]}" "$@" 2>>"${HARNESS_LOG}")" || {
      local rc=$?
      _log "hook ${hook_map[$base]} exited ${rc} during ${stage}"
      printf '%s' "${current}"; return ${rc}
    }
  done < <(printf '%s\n' "${!hook_map[@]}" | sort)

  printf '%s' "${current}"
}

# --------------------------------------------------------------------------- #
#  Main agent loop — pure state follower                                      #
# --------------------------------------------------------------------------- #
agent_loop() {
  local session_dir="$1"
  export SESSION_DIR="${session_dir}"
  trap 'printf "%s\n" "{\"type\":\"done\"}" >> "${SESSION_DIR}/.stream" 2>/dev/null' EXIT
  local state="start" context='{}' result="" rc=0 iterations=0

  while [[ -n "${state}" ]]; do
    _refresh_sources
    result="$(echo "${context}" | call "${state}")" && rc=0 || rc=$?

    if (( rc != 0 )); then
      [[ "${state}" == "error" ]] && break
      state="error"; context="${result}"; continue
    fi

    state="$(echo "${result}" | jq -r '.next_state // empty' 2>/dev/null)" || true
    context="$(echo "${result}" | jq -c 'del(.next_state)' 2>/dev/null)" || context='{}'

    (( ++iterations > HARNESS_MAX_TURNS * 3 )) && { _log "safety: exceeded max iterations"; break; }
  done

  local output; output="$(echo "${result:-}" | jq -r '.output // empty' 2>/dev/null)" || true
  [[ -n "${output}" ]] && printf '%s\n' "${output}"
}

# --------------------------------------------------------------------------- #
#  Utilities                                                                   #
# --------------------------------------------------------------------------- #
_log() { echo "[harness] $*" >> "${HARNESS_LOG}"; }
_die() { echo "harness: $*" >&2; exit 1; }

# --------------------------------------------------------------------------- #
#  Command discovery                                                           #
# --------------------------------------------------------------------------- #
# Commands are executables in commands/ directories within plugin sources.
# Protocol: --describe returns one-line help text; otherwise executed with args.
# Discovery follows the same source walk as tools/hooks: local overrides global.

_find_command() {
  local target="$1" result="" src
  for src in "${_HARNESS_SOURCES[@]}"; do
    [[ -x "${src}/commands/${target}" ]] && result="${src}/commands/${target}"
  done
  echo "${result}"
}

# --------------------------------------------------------------------------- #
#  CLI                                                                         #
# --------------------------------------------------------------------------- #
main() {
  command -v jq &>/dev/null || _die "required: jq"
  command -v curl &>/dev/null || _die "required: curl"
  mkdir -p "${HARNESS_HOME}" "${HARNESS_SESSIONS}"
  _refresh_sources

  local cmd="${1:-agent}"
  case "${cmd}" in --help|-h) cmd="help" ;; --version|-v) cmd="version" ;; esac

  # Interactive TTY with no message → REPL instead of agent
  if [[ -t 0 ]]; then
    if [[ $# -eq 0 ]]; then
      cmd="repl"
    elif [[ $# -eq 1 ]] && [[ -d "${HARNESS_SESSIONS}/${1}" ]]; then
      cmd="repl"; set -- repl "$@"
    fi
  fi

  local cmd_path="$(_find_command "${cmd}")"
  if [[ -n "${cmd_path}" ]]; then
    shift || true
  else
    cmd_path="$(_find_command "agent")" || true
    [[ -n "${cmd_path}" ]] || _die "no agent command found"
  fi
  exec "${cmd_path}" "$@"
}

# Only run main when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
