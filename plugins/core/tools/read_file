#!/usr/bin/env bash
# read_file — tool plugin: read file contents, optionally a line range.
set -euo pipefail

case "${1:-}" in
  --schema)
    cat <<'JSON'
{
  "name": "read_file",
  "description": "Read the contents of a file. Optionally specify a line range. Returns the file content in LINENUM#HASH:content format where #HASH is a 2-character verification anchor.",
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the file (absolute or relative to working directory)"
      },
      "offset": {
        "type": "integer",
        "description": "Line number to start reading from (1-indexed, default: 1)"
      },
      "limit": {
        "type": "integer",
        "description": "Maximum number of lines to read (default: entire file)"
      }
    },
    "required": ["path"]
  }
}
JSON
    ;;
  --describe)
    echo "Read file contents with optional line range"
    ;;
  --exec)
    input="$(cat)"
    path="$(echo "${input}" | jq -r '.path')"
    offset="$(echo "${input}" | jq -r '.offset // empty')"
    limit="$(echo "${input}" | jq -r '.limit // empty')"

    # Resolve relative paths against working directory
    if [[ "${path}" != /* ]]; then
      path="${HARNESS_CWD:-${PWD}}/${path}"
    fi

    if [[ ! -f "${path}" ]]; then
      echo "error: file not found: ${path}"
      exit 1
    fi

    max_lines="${HARNESS_READ_LIMIT:-2000}"
    total="$(wc -l < "${path}" | tr -d ' ')"
    start="${offset:-1}"

    if [[ -z "${limit}" && -z "${offset}" ]] && (( total > max_lines )); then
      echo "error: file has ${total} lines (limit: ${max_lines}). Use offset/limit to read a section, or use a subagent to search/summarize the full file."
      exit 1
    fi

    lib="$(dirname "$0")/../lib/hashline.awk"

    if [[ -n "${limit}" ]]; then
      awk -f "${lib}" -v start_line="${start}" -v max_lines="${limit}" < "${path}"
    elif [[ -n "${offset}" ]]; then
      awk -f "${lib}" -v start_line="${start}" < "${path}"
    else
      awk -f "${lib}" < "${path}"
    fi
    ;;
  *)
    echo "usage: read_file --schema | --describe | --exec" >&2
    exit 1
    ;;
esac
