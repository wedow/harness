#!/usr/bin/env bash
# bash — tool plugin: execute a bash command and return stdout+stderr.
set -euo pipefail

case "${1:-}" in
  --schema)
    cat <<'JSON'
{
  "name": "bash",
  "description": "Execute a bash command in the working directory. Returns combined stdout and stderr. Use for running scripts, installing packages, file operations, or any shell command.",
  "input_schema": {
    "type": "object",
    "properties": {
      "command": {
        "type": "string",
        "description": "The bash command to execute"
      },
      "timeout": {
        "type": "integer",
        "description": "Timeout in seconds (default: 120)"
      }
    },
    "required": ["command"]
  }
}
JSON
    ;;
  --describe)
    echo "Execute bash commands"
    ;;
  --exec)
    input="$(cat)"
    command="$(echo "${input}" | jq -r '.command')"
    tool_timeout="$(echo "${input}" | jq -r '.timeout // empty')"
    # Run in the session's original cwd if available
    cwd="${HARNESS_CWD:-${PWD}}"
    cd "${cwd}" 2>/dev/null || true
    # Execute with a timeout, capture both stdout and stderr
    _timeout="${tool_timeout:-${HARNESS_TOOL_TIMEOUT:-120}}"
    if command -v timeout &>/dev/null; then
      timeout "${_timeout}" bash -c "${command}" 2>&1 || true
    else
      # macOS: background + watchdog kill (no GNU timeout)
      bash -c "${command}" 2>&1 & _pid=$!
      ( sleep "${_timeout}" && kill "${_pid}" 2>/dev/null ) & _wd=$!
      wait "${_pid}" 2>/dev/null || true
      kill "${_wd}" 2>/dev/null || true; wait "${_wd}" 2>/dev/null || true
    fi
    ;;
  *)
    echo "usage: bash --schema | --describe | --exec" >&2
    exit 1
    ;;
esac
