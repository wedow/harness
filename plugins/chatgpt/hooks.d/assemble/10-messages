#!/usr/bin/env bash
# 10-messages — read canonical session files, produce Responses API input items.
# Pipeline hook: receives partial payload on stdin, adds "messages" field.
set -euo pipefail

payload="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"

[[ -d "${msg_dir}" ]] || { echo "${payload}"; exit 0; }

messages="[]"

add_item() {
  messages="$(echo "${messages}" | jq --argjson m "$1" '. + [$m]')"
}

for f in $(ls -1 "${msg_dir}"/*.md 2>/dev/null | sort); do
  _role=""
  _call_id=""
  _error="false"
  in_fm=false
  body=""
  while IFS= read -r line; do
    if [[ "${line}" == "---" ]]; then
      if ${in_fm}; then in_fm=false; continue
      else in_fm=true; continue; fi
    fi
    if ${in_fm}; then
      case "${line}" in
        role:*)     _role="${line#role: }" ;;
        call_id:*)  _call_id="${line#call_id: }" ;;
        error:*)    _error="${line#error: }" ;;
      esac
    else
      body+="${line}"$'\n'
    fi
  done < "${f}"
  body="${body%$'\n'}"

  case "${_role}" in
    user)
      add_item "$(jq -n --arg c "${body}" '{type: "message", role: "user", content: [{type: "input_text", text: $c}]}')"
      ;;
    assistant)
      # Parse text and tool_call blocks
      text_content=""
      in_tool_block=false
      tool_id="" tool_name="" tool_body=""

      while IFS= read -r line; do
        if [[ "${line}" =~ ^\`\`\`tool_call\ id=([^ ]+)\ name=([^ ]+) ]]; then
          in_tool_block=true
          tool_id="${BASH_REMATCH[1]}"
          tool_name="${BASH_REMATCH[2]}"
          tool_body=""
          continue
        fi
        if ${in_tool_block} && [[ "${line}" == '```' ]]; then
          in_tool_block=false
          # Emit function_call item
          add_item "$(jq -n --arg name "${tool_name}" --arg args "${tool_body}" --arg id "${tool_id}" \
            '{type: "function_call", name: $name, arguments: $args, call_id: $id}')"
          continue
        fi
        if ${in_tool_block}; then
          tool_body+="${line}"
        else
          text_content+="${line}"$'\n'
        fi
      done <<< "${body}"
      text_content="${text_content%$'\n'}"

      # Emit message item for text content (if any)
      if [[ -n "${text_content}" ]]; then
        add_item "$(jq -n --arg c "${text_content}" \
          '{type: "message", role: "assistant", content: [{type: "output_text", text: $c}]}')"
      fi
      ;;
    tool_result)
      # Responses API: function_call_output
      add_item "$(jq -n --arg id "${_call_id}" --arg out "${body}" \
        '{type: "function_call_output", call_id: $id, output: $out}')"
      ;;
  esac
done

echo "${payload}" | jq --argjson msgs "${messages}" '. + {messages: $msgs}'
