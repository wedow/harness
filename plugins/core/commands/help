#!/usr/bin/env bash
# harness help — show usage, discovered commands, providers, tools, and plugin info
set -euo pipefail

case "${1:-}" in
  --describe) echo "show usage and discovered plugins"; exit 0 ;;
esac

source "${HARNESS_ROOT}/bin/harness"

_collect_tools_from() {
  local dir="$1"
  local -n tmap_ref="$2"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    tmap_ref["$(basename "${f}")"]="${f}"
  done
}

_discover_providers() {
  # Walk bundled plugins + .harness/ dirs WITHOUT provider scoping
  local all_sources=()

  local d
  for d in "${HARNESS_ROOT}/plugins"/*/; do
    [[ -d "${d}" ]] && all_sources+=("${d%/}")
  done

  local harness_dirs=()
  local cur="${PWD}"
  while true; do
    [[ -d "${cur}/.harness" ]] && harness_dirs+=("${cur}/.harness")
    [[ "${cur}" == "/" ]] && break
    cur="$(dirname "${cur}")"
  done
  local found=0
  for d in "${harness_dirs[@]:-}"; do
    [[ "${d}" == "${HARNESS_HOME}" ]] && found=1
  done
  (( found )) || harness_dirs+=("${HARNESS_HOME}")

  local i
  for (( i=${#harness_dirs[@]}-1; i>=0; i-- )); do
    local hd="${harness_dirs[i]}"
    for d in "${hd}/plugins"/*/; do
      [[ -d "${d}" ]] && all_sources+=("${d%/}")
    done
    all_sources+=("${hd}")
  done

  declare -A prov_map
  local src
  for src in "${all_sources[@]}"; do
    local dir="${src}/providers"
    [[ -d "${dir}" ]] || continue
    local f
    for f in "${dir}"/*; do
      [[ -x "${f}" ]] || continue
      prov_map["$(basename "${f}")"]="${f}"
    done
  done
  for name in "${!prov_map[@]}"; do
    echo "${name} ${prov_map[$name]}"
  done
}

cat <<'EOF'
harness — minimal agent loop, maximum extensibility

usage:
  hs "do something"         one-shot: run agent with a message
  hs                        interactive REPL (new session)
  hs <session-id>           resume a session
  hs agent [args...]        explicit (same as above)
  hs session <sub> [args]  manage sessions (list, show <id>, dir [id])
  hs tools                 list discovered tools
  hs hooks [stage]         list discovered hooks
  hs version               print version
  hs help                  this message
EOF

# Discover plugin-added commands beyond the built-ins
_discover_sources
declare -A cmd_map
local_cmds=()
for src in "${_HARNESS_SOURCES[@]}"; do
  [[ -d "${src}/commands" ]] || continue
  for f in "${src}/commands"/*; do
    [[ -x "${f}" && -f "${f}" ]] || continue
    cmd_map["$(basename "${f}")"]="${f}"
  done
done
# Show any commands not already listed in the usage block
builtin_cmds="agent session tools hooks version help"
for name in $(printf '%s\n' "${!cmd_map[@]}" | sort); do
  [[ " ${builtin_cmds} " == *" ${name} "* ]] && continue
  path="${cmd_map[$name]}"
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  local_cmds+=("$(printf '  %-20s %s' "${name}" "${desc}")")
done
if (( ${#local_cmds[@]} > 0 )); then
  echo ""
  echo "plugin commands:"
  printf '%s\n' "${local_cmds[@]}"
fi

echo ""
echo "environment:"
cat <<'EOF'
  HARNESS_HOME             base directory (~/.harness)
  HARNESS_MODEL            model (auto from provider --defaults)
  HARNESS_PROVIDER         provider (auto: first with credentials)
  HARNESS_MAX_TURNS        max agent loop iterations (100)
EOF

echo ""
echo "providers (discovered):"
while read -r name path; do
  [[ -z "${name}" ]] && continue
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  printf '  %-20s %s\n' "${name}" "${desc}"
  while IFS= read -r envline; do
    [[ -n "${envline}" ]] && printf '    %s\n' "${envline}"
  done < <("${path}" --env 2>/dev/null || true)
done < <(_discover_providers)

echo ""
echo "tools (discovered):"
declare -A tool_map
for src in "${_HARNESS_SOURCES[@]}"; do
  _collect_tools_from "${src}/tools" tool_map
done
for name in "${!tool_map[@]}"; do
  path="${tool_map[$name]}"
  desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
  printf '  %-20s %s\n' "${name}" "${desc}"
done

echo ""
cat <<'EOF'
plugin dirs:
  .harness/ directories are discovered by walking from CWD up to /.
  each can contain: commands/ hooks.d/ tools/ providers/ plugins/
  bundled plugins live in <harness-root>/plugins/*/
  plugin packs in .harness/plugins/*/ follow the same layout.
  local dirs override global ones (by basename).
EOF
