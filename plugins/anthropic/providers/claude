#!/usr/bin/env bash
# claude — Claude.ai OAuth provider. Handles auth and delegates to anthropic.
set -euo pipefail

[[ "${1:-}" == "--describe" ]] && { echo "Claude.ai (OAuth)"; exit 0; }
[[ "${1:-}" == "--ready" ]] && {
  cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
  [[ -f "${cache}" ]] || exit 1
  jq -e '.claude | length > 0' "${cache}" &>/dev/null || exit 1
  exp="$(jq -r '.claude[0].expires_at // "0"' "${cache}")"
  [[ "${exp}" == "0" ]] || [[ "$(date +%s)" -lt "${exp}" ]]
  exit $?
}
[[ "${1:-}" == "--defaults" ]] && { echo "model=claude-sonnet-4-6"; exit 0; }
[[ "${1:-}" == "--env" ]] && { cat <<'ENVEOF'
ANTHROPIC_MAX_TOKENS  max response tokens (8192)
ENVEOF
exit 0; }

# --stream is passed through to the anthropic provider
[[ "${1:-}" == "--stream" ]] && { _stream="--stream"; shift; } || _stream=""

cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
[[ -f "${cache}" ]] || { echo "no auth cache — run: hs auth set claude" >&2; exit 1; }

# Read credentials
access_token="$(jq -r '.claude[0].access_token // empty' "${cache}")"
refresh_token="$(jq -r '.claude[0].refresh_token // empty' "${cache}")"
expires_at="$(jq -r '.claude[0].expires_at // "0"' "${cache}")"

[[ -z "${access_token}" ]] && { echo "no claude access_token — run: hs auth set claude" >&2; exit 1; }

# Refresh token if expired
now="$(date +%s)"
if [[ -n "${refresh_token}" && "${expires_at}" != "0" && "${now}" -ge "${expires_at}" ]]; then
  token_response="$(curl -sS -X POST "https://platform.claude.com/v1/oauth/token" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    -H "User-Agent: node" \
    -d "$(jq -n \
      --arg client_id "9d1c250a-e61b-44d9-88ed-5944d1962f5e" \
      --arg refresh_token "${refresh_token}" \
      '{client_id: $client_id, grant_type: "refresh_token", refresh_token: $refresh_token}'
    )" --max-time 30)" || { echo "token refresh failed" >&2; exit 1; }

  new_access="$(echo "${token_response}" | jq -r '.access_token // empty')"
  [[ -z "${new_access}" ]] && {
    echo "token refresh failed ($(echo "${token_response}" | jq -r '.error_description // .error.message // .error // "unknown"' 2>/dev/null)) — run: hs auth set claude" >&2
    exit 1
  }

  new_refresh="$(echo "${token_response}" | jq -r '.refresh_token // empty')"
  expires_in="$(echo "${token_response}" | jq -r '.expires_in // "0"')"
  new_expires_at="$(( $(date +%s) + expires_in - 300 ))"

  access_token="${new_access}"
  [[ -n "${new_refresh}" && "${new_refresh}" != "null" ]] && refresh_token="${new_refresh}"

  # Update source .auth.json (walk sources to find the one with claude creds)
  IFS=':' read -ra _auth_sources <<< "${HARNESS_SOURCES}"
  auth_file=""
  for _s in "${_auth_sources[@]}"; do
    [[ -f "${_s}/.auth.json" ]] && jq -e '.claude | length > 0' "${_s}/.auth.json" &>/dev/null && auth_file="${_s}/.auth.json"
  done
  if [[ -n "${auth_file}" ]]; then
    updated="$(jq \
      --arg at "${access_token}" \
      --arg rt "${refresh_token}" \
      --arg exp "${new_expires_at}" \
      '.claude[0].access_token = $at
       | .claude[0].refresh_token = $rt
       | .claude[0].expires_at = $exp' "${auth_file}")"
    _tmp="$(mktemp "${auth_file}.XXXXXX")"
    echo "${updated}" > "${_tmp}" && chmod 600 "${_tmp}" && mv -f "${_tmp}" "${auth_file}"
  fi
  # Also update cache for this run
  updated="$(jq \
    --arg at "${access_token}" \
    --arg rt "${refresh_token}" \
    --arg exp "${new_expires_at}" \
    '.claude[0].access_token = $at
     | .claude[0].refresh_token = $rt
     | .claude[0].expires_at = $exp' "${cache}")"
  _tmp="$(mktemp "${cache}.XXXXXX")"
  echo "${updated}" > "${_tmp}" && chmod 600 "${_tmp}" && mv -f "${_tmp}" "${cache}"
  echo "refreshed claude token" >&2
fi

# Configure anthropic provider for OAuth
export ANTHROPIC_AUTH_HEADER="Authorization: Bearer ${access_token}"
export ANTHROPIC_BETA="claude-code-20250219,oauth-2025-04-20"

# Find the anthropic provider
IFS=':' read -ra _sources <<< "${HARNESS_SOURCES}"
_anthropic=""
for (( _i=${#_sources[@]}-1; _i>=0; _i-- )); do
  [[ -x "${_sources[_i]}/providers/anthropic" ]] && _anthropic="${_sources[_i]}/providers/anthropic"
done
[[ -z "${_anthropic}" ]] && { echo "anthropic provider not found" >&2; exit 1; }

# Pre-process: system prompt as cached content blocks with identity
payload="$(cat)"
system="$(echo "${payload}" | jq -r '.system // ""')"
identity='You are Claude Code, Anthropic'\''s official CLI for Claude.'
if [[ -n "${system}" ]]; then
  system_blocks="$(printf '%s' "${system}" | jq -Rs --arg identity "${identity}" \
    '[{type: "text", text: $identity, cache_control: {type: "ephemeral"}},
      {type: "text", text: ., cache_control: {type: "ephemeral"}}]'
  )"
else
  system_blocks="$(jq -n \
    --arg identity "${identity}" \
    '[{type: "text", text: $identity, cache_control: {type: "ephemeral"}}]'
  )"
fi
payload="$(printf '%s\n%s' "${payload}" "${system_blocks}" | jq -c -s '.[0] + {system: .[1]}')"

echo "${payload}" | "${_anthropic}" ${_stream} "$@"
