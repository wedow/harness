#!/usr/bin/env bash
# 30-prompts — load system prompt content from the filesystem.
#
# Iterates HARNESS_SOURCES (global first = lowest priority first in the list),
# collecting AGENTS.md files and prompts/*.md from each source.
#
# AGENTS.md follows the agents.md standard (https://agents.md): the file lives
# at the project root (the parent of each .harness/ source directory), not
# inside .harness/ itself.  Additional prompt fragments in prompts/*.md remain
# a harness-specific composability feature (including the core system prompt
# at plugins/core/prompts/001-system.md).
set -euo pipefail

payload="$(cat)"
system_parts=()

# Iterate HARNESS_SOURCES (global first = lowest priority first)
IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"
for src in "${sources[@]}"; do
  # AGENTS.md at the parent of this source (agents.md standard location)
  parent="$(dirname "${src}")"
  [[ -f "${parent}/AGENTS.md" ]] && system_parts+=("$(cat "${parent}/AGENTS.md")")

  # All .md files in prompts/ sorted (harness-specific composability)
  if [[ -d "${src}/prompts" ]]; then
    for f in $(ls -1 "${src}/prompts/"*.md 2>/dev/null | sort); do
      system_parts+=("$(cat "${f}")")
    done
  fi
done

# Join with double newlines
system=""
for part in "${system_parts[@]}"; do
  [[ -z "${part}" ]] && continue
  if [[ -n "${system}" ]]; then
    system+=$'\n\n'
  fi
  system+="${part}"
done

# Add system prompt to payload as a top-level "system" field
echo "${payload}" | jq --arg sys "${system}" '. + {system: $sys, next_state: "send"}'
