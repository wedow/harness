#!/usr/bin/env bash
# harness — minimal agent loop. everything else is plugins.
set -euo pipefail

HARNESS_VERSION="0.1.0"
readonly HARNESS_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
# Overridable
HARNESS_HOME="${HARNESS_HOME:-${HOME}/.harness}"
# Session store: walk up from CWD to find nearest .harness/sessions/, else ~/.harness/sessions
if [[ -z "${HARNESS_SESSIONS:-}" ]]; then
  _cur="${PWD}"
  while true; do
    if [[ -d "${_cur}/.harness/sessions" ]]; then
      HARNESS_SESSIONS="${_cur}/.harness/sessions"
      break
    fi
    [[ "${_cur}" == "/" ]] && break
    _cur="$(dirname "${_cur}")"
  done
  HARNESS_SESSIONS="${HARNESS_SESSIONS:-${HARNESS_HOME}/sessions}"
  unset _cur
fi
HARNESS_MODEL="${HARNESS_MODEL:-}"
HARNESS_PROVIDER="${HARNESS_PROVIDER:-}"
HARNESS_MAX_TURNS="${HARNESS_MAX_TURNS:-100}"
HARNESS_LOG="${HARNESS_LOG:-/dev/stderr}"

# Baked-in system prompt. Keep this under 50 words.
# Everything else comes from plugins (see 30-prompts hook).
HARNESS_SYSTEM="You are an autonomous agent running in a terminal. Use your tools to complete the task. Be direct. When done, say DONE."

# State machine default transitions
declare -A DEFAULT_NEXT=(
  [start]=assemble
  [assemble]=send
  [send]=receive
  [receive]=done
  [tool_exec]=tool_done
  [tool_done]=assemble
  [error]=done
)

# --------------------------------------------------------------------------- #
#  Source discovery                                                            #
# --------------------------------------------------------------------------- #
# Fully dynamic — called every loop iteration. Walks CWD upward collecting
# .harness/ dirs and bundled plugins. Provider plugins (dirs containing a
# providers/ subdir) are skipped if their basename != HARNESS_PROVIDER.

_HARNESS_SOURCES=()

_discover_sources() {
  _HARNESS_SOURCES=()

  # Bundled plugins (lowest priority)
  local d
  for d in "${HARNESS_ROOT}/plugins"/*/; do
    [[ -d "${d}" ]] || continue
    d="${d%/}"
    if [[ -d "${d}/providers" && "$(basename "${d}")" != "${HARNESS_PROVIDER}" ]]; then
      continue
    fi
    _HARNESS_SOURCES+=("${d}")
  done

  # Collect .harness/ dirs: CWD upward (most-local first)
  local harness_dirs=()
  local cur="${PWD}"
  while true; do
    [[ -d "${cur}/.harness" ]] && harness_dirs+=("${cur}/.harness")
    [[ "${cur}" == "/" ]] && break
    cur="$(dirname "${cur}")"
  done
  # Ensure ~/.harness always present
  local found=0
  for d in "${harness_dirs[@]:-}"; do
    [[ "${d}" == "${HARNESS_HOME}" ]] && found=1
  done
  (( found )) || harness_dirs+=("${HARNESS_HOME}")

  # Process global-first (reverse of harness_dirs)
  local i
  for (( i=${#harness_dirs[@]}-1; i>=0; i-- )); do
    local hd="${harness_dirs[i]}"
    for d in "${hd}/plugins"/*/; do
      [[ -d "${d}" ]] || continue
      d="${d%/}"
      if [[ -d "${d}/providers" && "$(basename "${d}")" != "${HARNESS_PROVIDER}" ]]; then
        continue
      fi
      _HARNESS_SOURCES+=("${d}")
    done
    _HARNESS_SOURCES+=("${hd}")
  done

  # Export colon-separated list for hooks
  local joined=""
  for d in "${_HARNESS_SOURCES[@]}"; do
    [[ -n "${joined}" ]] && joined+=":"
    joined+="${d}"
  done
  export HARNESS_SOURCES="${joined}"
}

# --------------------------------------------------------------------------- #
#  Hook runner                                                                 #
# --------------------------------------------------------------------------- #
# Hooks are executables in hooks.d/<stage>/ directories. They are collected
# from all sources (local overrides global by basename), sorted by numeric
# prefix, and run as a pipeline: each hook's stdout feeds the next hook's
# stdin. Non-zero exit aborts the chain.

run_hooks() {
  local stage="$1"; shift
  local extra_args=("$@")

  # Collect hooks from all sources (lowest to highest priority).
  # Later entries override earlier ones sharing the same basename.
  declare -A hook_map
  local order=()

  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    _collect_hooks_from "${src}/hooks.d/${stage}" hook_map order
  done

  # Sort by basename (numeric prefix gives order)
  mapfile -t sorted < <(printf '%s\n' "${order[@]}" | sort -t/ -k1,1)

  # Resolve back to full paths, deduplicated
  local hooks=()
  local seen=()
  for base in "${sorted[@]:-}"; do
    [[ -z "${base}" ]] && continue
    local dup=0
    for s in "${seen[@]:-}"; do [[ "$s" == "$base" ]] && dup=1; done
    (( dup )) && continue
    seen+=("$base")
    hooks+=("${hook_map[$base]}")
  done

  # Run the pipeline
  local current=""
  [[ ! -t 0 ]] && current="$(cat)"

  export HARNESS_SESSION="${SESSION_DIR:-}" HARNESS_STAGE="${stage}"
  export HARNESS_MODEL HARNESS_PROVIDER HARNESS_SYSTEM HARNESS_ROOT
  export HARNESS_LOG HARNESS_SOURCES

  for hook in "${hooks[@]:-}"; do
    [[ -z "${hook}" ]] && continue
    current="$(
      echo "${current}" | "${hook}" "${extra_args[@]}" 2>>"${HARNESS_LOG}"
    )"
    local rc=$?
    if (( rc != 0 )); then
      _log "hook ${hook} exited ${rc} during ${stage}"
      printf '%s' "${current}"
      return ${rc}
    fi
  done

  printf '%s' "${current}"
}

_collect_hooks_from() {
  local dir="$1"
  local -n map_ref="$2"
  local -n order_ref="$3"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    local base="$(basename "${f}")"
    map_ref["${base}"]="${f}"
    local found=0
    for o in "${order_ref[@]:-}"; do [[ "$o" == "$base" ]] && found=1; done
    (( found )) || order_ref+=("${base}")
  done
}

# --------------------------------------------------------------------------- #
#  Tool discovery (for CLI commands)                                           #
# --------------------------------------------------------------------------- #
discover_tools() {
  _discover_sources
  declare -A tool_map

  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    _collect_tools_from "${src}/tools" tool_map
  done

  local schemas="[]"
  for name in "${!tool_map[@]}"; do
    local path="${tool_map[$name]}"
    local schema
    schema="$("${path}" --schema 2>/dev/null)" || continue
    schemas="$(echo "${schemas}" | jq --argjson s "${schema}" '. + [$s]')"
  done
  echo "${schemas}"
}

_collect_tools_from() {
  local dir="$1"
  local -n tmap_ref="$2"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    local name="$(basename "${f}")"
    tmap_ref["${name}"]="${f}"
  done
}

# --------------------------------------------------------------------------- #
#  Provider discovery (unscoped — sees ALL providers)                          #
# --------------------------------------------------------------------------- #
discover_providers() {
  # Walk bundled plugins + .harness/ dirs WITHOUT provider scoping
  local all_sources=()

  local d
  for d in "${HARNESS_ROOT}/plugins"/*/; do
    [[ -d "${d}" ]] && all_sources+=("${d%/}")
  done

  local harness_dirs=()
  local cur="${PWD}"
  while true; do
    [[ -d "${cur}/.harness" ]] && harness_dirs+=("${cur}/.harness")
    [[ "${cur}" == "/" ]] && break
    cur="$(dirname "${cur}")"
  done
  local found=0
  for d in "${harness_dirs[@]:-}"; do
    [[ "${d}" == "${HARNESS_HOME}" ]] && found=1
  done
  (( found )) || harness_dirs+=("${HARNESS_HOME}")

  local i
  for (( i=${#harness_dirs[@]}-1; i>=0; i-- )); do
    local hd="${harness_dirs[i]}"
    for d in "${hd}/plugins"/*/; do
      [[ -d "${d}" ]] && all_sources+=("${d%/}")
    done
    all_sources+=("${hd}")
  done

  declare -A prov_map
  local src
  for src in "${all_sources[@]}"; do
    local dir="${src}/providers"
    [[ -d "${dir}" ]] || continue
    local f
    for f in "${dir}"/*; do
      [[ -x "${f}" ]] || continue
      prov_map["$(basename "${f}")"]="${f}"
    done
  done
  for name in "${!prov_map[@]}"; do
    echo "${name} ${prov_map[$name]}"
  done
}

find_provider() {
  local name="$1"
  _discover_sources
  local i
  for (( i=${#_HARNESS_SOURCES[@]}-1; i>=0; i-- )); do
    [[ -x "${_HARNESS_SOURCES[i]}/providers/${name}" ]] && {
      echo "${_HARNESS_SOURCES[i]}/providers/${name}"
      return 0
    }
  done
  _log "provider '${name}' not found"
  return 1
}

_resolve_provider() {
  if [[ -z "${HARNESS_PROVIDER}" ]]; then
    local name path
    while read -r name path; do
      [[ -z "${name}" ]] && continue
      if "${path}" --ready 2>/dev/null; then
        HARNESS_PROVIDER="${name}"
        break
      fi
    done < <(discover_providers | sort)
  fi
  [[ -z "${HARNESS_PROVIDER}" ]] && return 0
  local provider_path
  provider_path="$(find_provider "${HARNESS_PROVIDER}")" || return 0
  local key val
  while IFS='=' read -r key val; do
    [[ -z "${key}" ]] && continue
    case "${key}" in
      model) [[ -z "${HARNESS_MODEL}" ]] && HARNESS_MODEL="${val}" ;;
    esac
  done < <("${provider_path}" --defaults 2>/dev/null || true)
  return 0
}

# --------------------------------------------------------------------------- #
#  Session management                                                         #
# --------------------------------------------------------------------------- #
session_new() {
  local id
  id="$(date +%Y%m%d-%H%M%S)-$$"
  local dir="${HARNESS_SESSIONS}/${id}"
  mkdir -p "${dir}/messages"
  cat > "${dir}/session.md" <<EOF
---
id: ${id}
model: ${HARNESS_MODEL}
provider: ${HARNESS_PROVIDER}
created: $(date -Iseconds)
cwd: ${PWD}
---
EOF
  echo "${dir}"
}

session_latest() {
  ls -1td "${HARNESS_SESSIONS}"/*/ 2>/dev/null | head -1
}

next_seq() {
  local dir="$1"
  local last
  last="$(ls -1 "${dir}/messages/" 2>/dev/null | sort -n | tail -1)"
  if [[ -z "${last}" ]]; then
    echo "0001"
  else
    printf '%04d' $(( 10#${last%%-*} + 1 ))
  fi
}

save_user_message() {
  local dir="$1" content="$2"
  local seq; seq="$(next_seq "${dir}")"
  cat > "${dir}/messages/${seq}-user.md" <<EOF
---
role: user
seq: ${seq}
timestamp: $(date -Iseconds)
---
${content}
EOF
}

# --------------------------------------------------------------------------- #
#  Main agent loop — pure state machine                                       #
# --------------------------------------------------------------------------- #
agent_loop() {
  local session_dir="$1"
  export SESSION_DIR="${session_dir}"

  [[ -z "${HARNESS_PROVIDER}" ]] && _die "no provider available. set HARNESS_PROVIDER or export an API key for a discovered provider."

  local state="start"
  local context='{}'
  local turns=0
  local output=""

  while true; do
    _discover_sources

    local result="" rc=0
    result="$(echo "${context}" | run_hooks "${state}")" && rc=0 || rc=$?

    # Hook pipeline failure handling
    if (( rc != 0 )); then
      if [[ "${state}" == "error" ]]; then
        break
      fi
      state="error"
      context="${result}"
      continue
    fi

    # Extract control fields
    local next_state=""
    next_state="$(echo "${result}" | jq -r '.next_state // empty' 2>/dev/null)" || true
    [[ -z "${next_state}" ]] && next_state="${DEFAULT_NEXT[${state}]:-}"

    local items=""
    items="$(echo "${result}" | jq -c '.items // empty' 2>/dev/null)" || true

    # Strip control fields to get context for next state
    context="$(echo "${result}" | jq -c 'del(.next_state, .items, .output)' 2>/dev/null)" || context='{}'
    [[ -z "${context}" || "${context}" == "null" ]] && context='{}'

    # Capture output for display at the end
    local step_output=""
    step_output="$(echo "${result}" | jq -r '.output // empty' 2>/dev/null)" || true
    [[ -n "${step_output}" ]] && output="${step_output}"

    # If current state is done, break (done hooks already ran)
    if [[ "${state}" == "done" ]]; then
      break
    fi

    # Process items if present
    if [[ -n "${items}" && "${items}" != "null" && "${items}" != "[]" ]]; then
      local item_state="${next_state}"
      local after_item="${DEFAULT_NEXT[${item_state}]:-}"
      local item_count
      item_count="$(echo "${items}" | jq 'length')"

      local idx
      for (( idx=0; idx<item_count; idx++ )); do
        local item
        item="$(echo "${items}" | jq -c ".[${idx}]")"

        _discover_sources
        local item_result=""
        item_result="$(echo "${item}" | run_hooks "${item_state}")" && true || true

        if [[ -n "${after_item}" ]]; then
          _discover_sources
          echo "${item_result}" | run_hooks "${after_item}" > /dev/null && true || true
        fi
      done

      state="assemble"
      context='{}'
    else
      state="${next_state}"
    fi

    # Count turns when entering send
    if [[ "${state}" == "send" ]]; then
      turns=$((turns + 1))
    fi
    if (( turns > HARNESS_MAX_TURNS )); then
      break
    fi
  done

  # Print output
  if [[ -n "${output}" ]]; then
    printf '%s\n' "${output}"
  fi

  if (( turns > HARNESS_MAX_TURNS )); then
    _log "hit max turns (${HARNESS_MAX_TURNS})"
  fi
}

# --------------------------------------------------------------------------- #
#  Utilities                                                                   #
# --------------------------------------------------------------------------- #
_log() {
  echo "[harness] $*" >> "${HARNESS_LOG}"
}

_die() {
  echo "harness: $*" >&2
  exit 1
}

_require() {
  command -v "$1" &>/dev/null || _die "required command '$1' not found"
}

# --------------------------------------------------------------------------- #
#  CLI                                                                         #
# --------------------------------------------------------------------------- #
cmd_run() {
  local message=""
  if (( $# > 0 )); then
    message="$*"
  elif [[ ! -t 0 ]]; then
    message="$(cat)"
  else
    _die "usage: harness run <message>"
  fi

  local session_dir
  session_dir="$(session_new)"
  _log "session: ${session_dir}"
  echo "session: $(basename "${session_dir}")" >&2

  save_user_message "${session_dir}" "${message}"
  agent_loop "${session_dir}"
}

cmd_chat() {
  local session_dir
  if [[ -n "${1:-}" ]]; then
    session_dir="${HARNESS_SESSIONS}/$1"
    [[ -d "${session_dir}" ]] || _die "session '$1' not found"
  else
    session_dir="$(session_new)"
    echo "session: $(basename "${session_dir}")" >&2
  fi

  while true; do
    printf '\n\033[1;36mYou:\033[0m '
    local input
    IFS= read -r input || break
    [[ -z "${input}" ]] && continue
    [[ "${input}" == "/quit" || "${input}" == "/exit" ]] && break

    if [[ "${input}" == "/session" ]]; then
      echo "${session_dir}"
      continue
    fi

    save_user_message "${session_dir}" "${input}"
    printf '\033[1;33mAgent:\033[0m '
    agent_loop "${session_dir}"
    echo
  done
}

cmd_session() {
  local subcmd="${1:-list}"; shift || true
  case "${subcmd}" in
    list)
      ls -1t "${HARNESS_SESSIONS}" 2>/dev/null || echo "(no sessions)"
      ;;
    show)
      local id="${1:?usage: harness session show <id>}"
      local dir="${HARNESS_SESSIONS}/${id}"
      [[ -d "${dir}" ]] || _die "session '${id}' not found"
      cat "${dir}/session.md"
      echo "---"
      echo "messages: $(ls -1 "${dir}/messages/" | wc -l)"
      ls -1 "${dir}/messages/"
      ;;
    dir)
      local id="${1:-}"
      if [[ -n "${id}" ]]; then
        echo "${HARNESS_SESSIONS}/${id}"
      else
        echo "${HARNESS_SESSIONS}"
      fi
      ;;
    *)
      _die "unknown session command: ${subcmd}"
      ;;
  esac
}

cmd_tools() {
  _discover_sources
  declare -A tool_map
  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    _collect_tools_from "${src}/tools" tool_map
  done
  for name in "${!tool_map[@]}"; do
    local path="${tool_map[$name]}"
    local desc=""
    desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
    printf '  %-20s %s  [%s]\n' "${name}" "${desc}" "${path}"
  done
}

cmd_hooks() {
  local stage="${1:-}"
  _discover_sources
  local search_dirs=()
  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    search_dirs+=("${src}/hooks.d")
  done
  for sd in "${search_dirs[@]}"; do
    [[ -d "${sd}" ]] || continue
    if [[ -n "${stage}" ]]; then
      [[ -d "${sd}/${stage}" ]] || continue
      for f in "${sd}/${stage}"/*; do
        [[ -x "$f" ]] && echo "  ${stage}/$(basename "$f")  [$f]"
      done
    else
      for stage_dir in "${sd}"/*/; do
        [[ -d "${stage_dir}" ]] || continue
        local sname="$(basename "${stage_dir}")"
        for f in "${stage_dir}"*; do
          [[ -x "$f" ]] && echo "  ${sname}/$(basename "$f")  [$f]"
        done
      done
    fi
  done
}

cmd_version() { echo "harness ${HARNESS_VERSION}"; }

cmd_help() {
  cat <<'EOF'
harness — minimal agent loop, maximum extensibility

usage:
  hs run <message>         one-shot: create session, run to completion
  hs chat [session-id]     interactive REPL (new or resume session)
  hs session list          list sessions
  hs session show <id>     inspect a session
  hs session dir [id]      print session directory path
  hs tools                 list discovered tools
  hs hooks [stage]         list discovered hooks
  hs version               print version
  hs help                  this message

environment:
  HARNESS_HOME             base directory (~/.harness)
  HARNESS_MODEL            model (auto from provider --defaults)
  HARNESS_PROVIDER         provider (auto: first with credentials)
  HARNESS_MAX_TURNS        max agent loop iterations (100)
EOF

  echo ""
  echo "providers (discovered):"
  local name path desc envline
  while read -r name path; do
    [[ -z "${name}" ]] && continue
    desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
    printf '  %-20s %s\n' "${name}" "${desc}"
    while IFS= read -r envline; do
      [[ -n "${envline}" ]] && printf '    %s\n' "${envline}"
    done < <("${path}" --env 2>/dev/null || true)
  done < <(discover_providers)

  echo ""
  echo "tools (discovered):"
  _discover_sources
  declare -A tool_map
  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    _collect_tools_from "${src}/tools" tool_map
  done
  for name in "${!tool_map[@]}"; do
    path="${tool_map[$name]}"
    desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
    printf '  %-20s %s\n' "${name}" "${desc}"
  done

  echo ""
  cat <<'EOF'
plugin dirs:
  .harness/ directories are discovered by walking from CWD up to /.
  each can contain: hooks.d/ tools/ providers/ plugins/
  bundled plugins live in <harness-root>/plugins/*/
  plugin packs in .harness/plugins/*/ follow the same layout.
  local dirs override global ones (by basename).
EOF
}

main() {
  _require jq
  _require curl
  mkdir -p "${HARNESS_HOME}" "${HARNESS_SESSIONS}"
  _resolve_provider

  local cmd="${1:-help}"; shift || true
  case "${cmd}" in
    run)     cmd_run "$@" ;;
    chat)    cmd_chat "$@" ;;
    session) cmd_session "$@" ;;
    tools)   cmd_tools "$@" ;;
    hooks)   cmd_hooks "$@" ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)       _die "unknown command: ${cmd}. try 'harness help'" ;;
  esac
}

# Only run main when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
