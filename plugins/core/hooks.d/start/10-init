#!/usr/bin/env bash
# 10-init — set up session environment on start.
# Reads session.conf to recover the original working directory and exports it.
set -euo pipefail

# Consume stdin (just {} for start hooks) and pass it through at the end
input="$(cat)"

if [[ -f "${HARNESS_SESSION}/session.conf" ]]; then
  cwd="$(sed -n 's/^cwd=//p' "${HARNESS_SESSION}/session.conf")"
  [[ -n "${cwd}" ]] && export HARNESS_CWD="${cwd}"
fi

echo "${input}" | jq '. + {next_state: "assemble"}'
