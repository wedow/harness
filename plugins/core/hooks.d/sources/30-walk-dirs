#!/usr/bin/env bash
# 30-walk-dirs — discover source directories via CWD-upward walk
set -euo pipefail

cat > /dev/null  # consume stdin

dirs=()

# Bundled plugins (lowest priority)
for d in "${HARNESS_ROOT}/plugins"/*/; do
  [[ -d "${d}" ]] || continue
  dirs+=("${d%/}")
done

# User dirs: walk CWD upward, global first via tac
while IFS= read -r hd; do
  # Plugin packs within each .harness/ dir
  for d in "${hd}/plugins"/*/; do
    [[ -d "${d}" ]] || continue
    dirs+=("${d%/}")
  done
  dirs+=("${hd}")
done < <(
  cur="${PWD}" seen_home=0
  { while true; do
      if [[ -d "${cur}/.harness" ]]; then
        echo "${cur}/.harness"
        [[ "${cur}/.harness" == "${HARNESS_HOME}" ]] && seen_home=1
      fi
      [[ "${cur}" == "/" ]] && break
      cur="$(dirname "${cur}")"
    done
    (( seen_home )) || echo "${HARNESS_HOME}"
  } | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--)print a[i]}'
)

# Output as JSON
printf '%s\n' "${dirs[@]}" | jq -R . | jq -s '{sources: .}'
