#!/usr/bin/env bash
# harness — minimal agent loop. everything else is plugins.
set -euo pipefail

HARNESS_VERSION="0.1.0"
readonly HARNESS_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
readonly HARNESS_CORE="${HARNESS_ROOT}/plugins/core"

# Overridable
HARNESS_HOME="${HARNESS_HOME:-${HOME}/.harness}"
HARNESS_SESSIONS="${HARNESS_SESSIONS:-${HARNESS_HOME}/sessions}"
HARNESS_MODEL="${HARNESS_MODEL:-claude-sonnet-4-20250514}"
HARNESS_PROVIDER="${HARNESS_PROVIDER:-anthropic}"
HARNESS_MAX_TURNS="${HARNESS_MAX_TURNS:-100}"
HARNESS_LOG="${HARNESS_LOG:-/dev/stderr}"

# Baked-in system prompt. Keep this under 50 words.
# Everything else comes from plugins (see 30-prompts hook).
HARNESS_SYSTEM="You are an autonomous agent running in a terminal. Use your tools to complete the task. Be direct. When done, say DONE."

# --------------------------------------------------------------------------- #
#  Directory walking                                                           #
# --------------------------------------------------------------------------- #
# Walk from CWD up to / collecting every .harness/ dir found.
# Result order: most-local first (CWD), most-global last (home/root).
discover_dirs() {
  local dirs=()
  local cur="${PWD}"
  while true; do
    [[ -d "${cur}/.harness" ]] && dirs+=("${cur}/.harness")
    [[ "${cur}" == "/" ]] && break
    cur="$(dirname "${cur}")"
  done
  # Ensure ~/.harness always present (may already be in list)
  local found=0
  for d in "${dirs[@]:-}"; do
    [[ "${d}" == "${HARNESS_HOME}" ]] && found=1
  done
  (( found )) || dirs+=("${HARNESS_HOME}")
  printf '%s\n' "${dirs[@]}"
}

# Cache discovered dirs for the session lifetime
_HARNESS_DIRS=()
_init_dirs() {
  if (( ${#_HARNESS_DIRS[@]} == 0 )); then
    mapfile -t _HARNESS_DIRS < <(discover_dirs)
  fi
}

# --------------------------------------------------------------------------- #
#  Hook runner                                                                 #
# --------------------------------------------------------------------------- #
# Hooks are executables in hooks.d/<stage>/ directories. They are collected
# from all .harness/ dirs (local overrides global by basename), sorted by
# numeric prefix, and run as a pipeline: each hook's stdout feeds the next
# hook's stdin. Non-zero exit aborts the chain.
#
# Environment passed to every hook:
#   HARNESS_SESSION  — path to current session dir
#   HARNESS_STAGE    — hook stage name
#   HARNESS_MODEL    — current model
#   HARNESS_PROVIDER — current provider
#   Plus any extra env vars set by the caller.

run_hooks() {
  local stage="$1"; shift
  # Extra args become positional params for the hooks
  local extra_args=("$@")

  _init_dirs

  # Collect hooks: iterate dirs from most-global to most-local so that
  # local entries override globals sharing the same basename.
  declare -A hook_map  # basename -> full path
  local order=()

  # Core plugins (lowest priority)
  _collect_hooks_from "${HARNESS_CORE}/hooks.d/${stage}" hook_map order

  # .harness/ dirs: most-global last in _HARNESS_DIRS, so reverse
  local i
  for (( i=${#_HARNESS_DIRS[@]}-1; i>=0; i-- )); do
    _collect_hooks_from "${_HARNESS_DIRS[i]}/hooks.d/${stage}" hook_map order
  done

  # Sort by basename (numeric prefix gives order)
  mapfile -t sorted < <(printf '%s\n' "${order[@]}" | sort -t/ -k1,1)

  # Resolve back to full paths, deduplicated
  local hooks=()
  local seen=()
  for base in "${sorted[@]:-}"; do
    [[ -z "${base}" ]] && continue
    # Skip if we already added this basename
    local dup=0
    for s in "${seen[@]:-}"; do [[ "$s" == "$base" ]] && dup=1; done
    (( dup )) && continue
    seen+=("$base")
    hooks+=("${hook_map[$base]}")
  done

  # Run the pipeline
  local current=""
  [[ ! -t 0 ]] && current="$(cat)"

  for hook in "${hooks[@]:-}"; do
    [[ -z "${hook}" ]] && continue
    current="$(
      echo "${current}" | \
      HARNESS_SESSION="${SESSION_DIR:-}" \
      HARNESS_STAGE="${stage}" \
      HARNESS_MODEL="${HARNESS_MODEL}" \
      HARNESS_PROVIDER="${HARNESS_PROVIDER}" \
      HARNESS_SYSTEM="${HARNESS_SYSTEM}" \
      HARNESS_ROOT="${HARNESS_ROOT}" \
      "${hook}" "${extra_args[@]}" 2>>"${HARNESS_LOG}"
    )"
    local rc=$?
    if (( rc != 0 )); then
      _log "hook ${hook} exited ${rc} during ${stage}"
      return ${rc}
    fi
  done

  printf '%s' "${current}"
}

_collect_hooks_from() {
  local dir="$1"
  local -n map_ref="$2"
  local -n order_ref="$3"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    local base="$(basename "${f}")"
    map_ref["${base}"]="${f}"
    # Track for sorting — avoid duplicates in order list
    local found=0
    for o in "${order_ref[@]:-}"; do [[ "$o" == "$base" ]] && found=1; done
    (( found )) || order_ref+=("${base}")
  done
}

# --------------------------------------------------------------------------- #
#  Tool discovery                                                              #
# --------------------------------------------------------------------------- #
# Tools are executables in tools/ directories that respond to --schema.
discover_tools() {
  _init_dirs
  declare -A tool_map  # name -> path (local overrides global)

  # Core tools (lowest priority)
  _collect_tools_from "${HARNESS_CORE}/tools" tool_map

  # .harness/ dirs (most-global to most-local)
  local i
  for (( i=${#_HARNESS_DIRS[@]}-1; i>=0; i-- )); do
    _collect_tools_from "${_HARNESS_DIRS[i]}/tools" tool_map
  done

  # Output as JSON array
  local schemas="[]"
  for name in "${!tool_map[@]}"; do
    local path="${tool_map[$name]}"
    local schema
    schema="$("${path}" --schema 2>/dev/null)" || continue
    schemas="$(echo "${schemas}" | jq --argjson s "${schema}" '. + [$s]')"
  done
  echo "${schemas}"
}

# Also export a lookup: tool name -> executable path
declare -A TOOL_PATHS
_build_tool_paths() {
  _init_dirs
  TOOL_PATHS=()
  _collect_tools_from "${HARNESS_CORE}/tools" TOOL_PATHS
  local i
  for (( i=${#_HARNESS_DIRS[@]}-1; i>=0; i-- )); do
    _collect_tools_from "${_HARNESS_DIRS[i]}/tools" TOOL_PATHS
  done
}

_collect_tools_from() {
  local dir="$1"
  local -n tmap_ref="$2"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    local name="$(basename "${f}")"
    tmap_ref["${name}"]="${f}"
  done
}

# --------------------------------------------------------------------------- #
#  Provider discovery                                                          #
# --------------------------------------------------------------------------- #
find_provider() {
  local name="$1"
  _init_dirs
  # Check .harness/ dirs (most-local first)
  for d in "${_HARNESS_DIRS[@]}"; do
    [[ -x "${d}/providers/${name}" ]] && { echo "${d}/providers/${name}"; return 0; }
  done
  # Check core
  [[ -x "${HARNESS_CORE}/providers/${name}" ]] && { echo "${HARNESS_CORE}/providers/${name}"; return 0; }
  _log "provider '${name}' not found"
  return 1
}

# --------------------------------------------------------------------------- #
#  Session management                                                          #
# --------------------------------------------------------------------------- #
session_new() {
  local id
  id="$(date +%Y%m%d-%H%M%S)-$$"
  local dir="${HARNESS_SESSIONS}/${id}"
  mkdir -p "${dir}/messages"
  cat > "${dir}/session.md" <<EOF
---
id: ${id}
model: ${HARNESS_MODEL}
provider: ${HARNESS_PROVIDER}
created: $(date -Iseconds)
cwd: ${PWD}
---
EOF
  echo "${dir}"
}

session_latest() {
  ls -1td "${HARNESS_SESSIONS}"/*/ 2>/dev/null | head -1
}

next_seq() {
  local dir="$1"
  local last
  last="$(ls -1 "${dir}/messages/" 2>/dev/null | sort -n | tail -1)"
  if [[ -z "${last}" ]]; then
    echo "0001"
  else
    printf '%04d' $(( 10#${last%%-*} + 1 ))
  fi
}

save_user_message() {
  local dir="$1" content="$2"
  local seq; seq="$(next_seq "${dir}")"
  cat > "${dir}/messages/${seq}-user.md" <<EOF
---
role: user
seq: ${seq}
timestamp: $(date -Iseconds)
---
${content}
EOF
}

# --------------------------------------------------------------------------- #
#  Main agent loop                                                             #
# --------------------------------------------------------------------------- #
agent_loop() {
  local session_dir="$1"
  export SESSION_DIR="${session_dir}"

  _build_tool_paths
  local provider_bin
  provider_bin="$(find_provider "${HARNESS_PROVIDER}")"

  run_hooks on-start </dev/null || true

  local turn=0
  while (( turn < HARNESS_MAX_TURNS )); do
    turn=$((turn + 1))
    _log "turn ${turn}"

    # Assemble request — the assemble hooks build the full API payload
    local payload
    payload="$(echo '{}' | run_hooks assemble)"

    # Send to provider
    local response
    response="$( echo "${payload}" | "${provider_bin}" 2>>"${HARNESS_LOG}" )"
    local rc=$?
    if (( rc != 0 )); then
      echo "${response}" | run_hooks on-error </dev/null || true
      _log "provider returned ${rc}, retrying in 5s..."
      sleep 5
      continue
    fi

    # Post-receive hooks (save the response, log costs, etc.)
    echo "${response}" | run_hooks receive || true

    # Check for tool use
    local stop_reason
    stop_reason="$(echo "${response}" | jq -r '.stop_reason // "end_turn"')"

    if [[ "${stop_reason}" != "tool_use" ]]; then
      # Print final text to stdout
      echo "${response}" | jq -r '.content[] | select(.type=="text") | .text' 2>/dev/null
      break
    fi

    # Extract and execute tool calls
    local tool_calls
    tool_calls="$(echo "${response}" | jq -c '.content[] | select(.type=="tool_use")')"

    while IFS= read -r tc; do
      [[ -z "${tc}" ]] && continue
      local tool_name tool_id tool_input
      tool_name="$(echo "${tc}" | jq -r '.name')"
      tool_id="$(echo "${tc}" | jq -r '.id')"
      tool_input="$(echo "${tc}" | jq -c '.input')"

      _log "tool: ${tool_name} (${tool_id})"

      # Find the tool executable
      local tool_bin="${TOOL_PATHS[${tool_name}]:-}"
      local result is_error="false"

      if [[ -z "${tool_bin}" ]]; then
        result="error: tool '${tool_name}' not found"
        is_error="true"
      else
        # pre-tool hooks can abort (non-zero exit)
        if echo "${tc}" | run_hooks pre-tool 2>/dev/null; then
          result="$(echo "${tool_input}" | "${tool_bin}" --exec 2>&1)" || is_error="true"
        else
          result="tool execution blocked by pre-tool hook"
          is_error="true"
        fi
      fi

      # post-tool hooks (save result, etc.)
      jq -n --arg id "${tool_id}" --arg name "${tool_name}" \
            --arg result "${result}" --arg is_error "${is_error}" \
            --argjson input "${tool_input}" \
        '{tool_use_id: $id, name: $name, input: $input, result: $result, is_error: ($is_error == "true")}' \
        | run_hooks tool-done || true

    done <<< "${tool_calls}"

  done

  run_hooks on-end </dev/null || true

  if (( turn >= HARNESS_MAX_TURNS )); then
    _log "hit max turns (${HARNESS_MAX_TURNS})"
  fi
}

# --------------------------------------------------------------------------- #
#  Utilities                                                                   #
# --------------------------------------------------------------------------- #
_log() {
  echo "[harness] $*" >> "${HARNESS_LOG}"
}

_die() {
  echo "harness: $*" >&2
  exit 1
}

_require() {
  command -v "$1" &>/dev/null || _die "required command '$1' not found"
}

# --------------------------------------------------------------------------- #
#  CLI                                                                         #
# --------------------------------------------------------------------------- #
cmd_run() {
  local message=""
  # Collect message from args or stdin
  if (( $# > 0 )); then
    message="$*"
  elif [[ ! -t 0 ]]; then
    message="$(cat)"
  else
    _die "usage: harness run <message>"
  fi

  local session_dir
  session_dir="$(session_new)"
  _log "session: ${session_dir}"
  echo "session: $(basename "${session_dir}")" >&2

  save_user_message "${session_dir}" "${message}"
  agent_loop "${session_dir}"
}

cmd_chat() {
  local session_dir
  if [[ -n "${1:-}" ]]; then
    session_dir="${HARNESS_SESSIONS}/$1"
    [[ -d "${session_dir}" ]] || _die "session '$1' not found"
  else
    session_dir="$(session_new)"
    echo "session: $(basename "${session_dir}")" >&2
  fi

  while true; do
    printf '\n\033[1;36mYou:\033[0m '
    local input
    IFS= read -r input || break
    [[ -z "${input}" ]] && continue
    [[ "${input}" == "/quit" || "${input}" == "/exit" ]] && break

    if [[ "${input}" == "/session" ]]; then
      echo "${session_dir}"
      continue
    fi

    save_user_message "${session_dir}" "${input}"
    printf '\033[1;33mAgent:\033[0m '
    agent_loop "${session_dir}"
    echo
  done
}

cmd_session() {
  local subcmd="${1:-list}"; shift || true
  case "${subcmd}" in
    list)
      ls -1t "${HARNESS_SESSIONS}" 2>/dev/null || echo "(no sessions)"
      ;;
    show)
      local id="${1:?usage: harness session show <id>}"
      local dir="${HARNESS_SESSIONS}/${id}"
      [[ -d "${dir}" ]] || _die "session '${id}' not found"
      cat "${dir}/session.md"
      echo "---"
      echo "messages: $(ls -1 "${dir}/messages/" | wc -l)"
      ls -1 "${dir}/messages/"
      ;;
    dir)
      local id="${1:-}"
      if [[ -n "${id}" ]]; then
        echo "${HARNESS_SESSIONS}/${id}"
      else
        echo "${HARNESS_SESSIONS}"
      fi
      ;;
    *)
      _die "unknown session command: ${subcmd}"
      ;;
  esac
}

cmd_tools() {
  _build_tool_paths
  for name in "${!TOOL_PATHS[@]}"; do
    local path="${TOOL_PATHS[$name]}"
    local desc=""
    desc="$("${path}" --describe 2>/dev/null)" || desc="(no description)"
    printf '  %-20s %s  [%s]\n' "${name}" "${desc}" "${path}"
  done
}

cmd_hooks() {
  local stage="${1:-}"
  _init_dirs
  local search_dirs=("${HARNESS_CORE}/hooks.d")
  for d in "${_HARNESS_DIRS[@]}"; do
    search_dirs+=("${d}/hooks.d")
  done
  for sd in "${search_dirs[@]}"; do
    [[ -d "${sd}" ]] || continue
    if [[ -n "${stage}" ]]; then
      [[ -d "${sd}/${stage}" ]] || continue
      for f in "${sd}/${stage}"/*; do
        [[ -x "$f" ]] && echo "  ${stage}/$(basename "$f")  [$f]"
      done
    else
      for stage_dir in "${sd}"/*/; do
        [[ -d "${stage_dir}" ]] || continue
        local sname="$(basename "${stage_dir}")"
        for f in "${stage_dir}"*; do
          [[ -x "$f" ]] && echo "  ${sname}/$(basename "$f")  [$f]"
        done
      done
    fi
  done
}

cmd_version() { echo "harness ${HARNESS_VERSION}"; }

cmd_help() {
  cat <<'EOF'
harness — minimal agent loop, maximum extensibility

usage:
  hs run <message>         one-shot: create session, run to completion
  hs chat [session-id]     interactive REPL (new or resume session)
  hs session list           list sessions
  hs session show <id>     inspect a session
  hs session dir [id]      print session directory path
  hs tools                  list discovered tools
  hs hooks [stage]          list discovered hooks
  hs version                print version
  hs help                   this message

environment:
  HARNESS_HOME              base directory (~/.harness)
  HARNESS_MODEL             model to use (claude-sonnet-4-20250514)
  HARNESS_PROVIDER          provider plugin name (anthropic)
  HARNESS_MAX_TURNS         max agent loop iterations (100)
  ANTHROPIC_API_KEY         API key for anthropic provider

plugin dirs:
  .harness/ directories are discovered by walking from CWD up to /.
  each can contain: hooks.d/ tools/ providers/
  local dirs override global ones (by basename).
EOF
}

main() {
  _require jq
  _require curl
  mkdir -p "${HARNESS_HOME}" "${HARNESS_SESSIONS}"

  local cmd="${1:-help}"; shift || true
  case "${cmd}" in
    run)     cmd_run "$@" ;;
    chat)    cmd_chat "$@" ;;
    session) cmd_session "$@" ;;
    tools)   cmd_tools "$@" ;;
    hooks)   cmd_hooks "$@" ;;
    version) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)       _die "unknown command: ${cmd}. try 'harness help'" ;;
  esac
}

# Only run main when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
