#!/usr/bin/env bash
# harness — minimal agent loop. everything else is plugins.
set -euo pipefail

HARNESS_VERSION="0.1.0"
HARNESS_ROOT="${HARNESS_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
readonly HARNESS_ROOT
# Overridable
HARNESS_HOME="${HARNESS_HOME:-${HOME}/.harness}"
# Session store: walk up from CWD to find nearest .harness/sessions/, else ~/.harness/sessions
if [[ -z "${HARNESS_SESSIONS:-}" ]]; then
  _cur="${PWD}"
  while true; do
    if [[ -d "${_cur}/.harness/sessions" ]]; then
      HARNESS_SESSIONS="${_cur}/.harness/sessions"
      break
    fi
    [[ "${_cur}" == "/" ]] && break
    _cur="$(dirname "${_cur}")"
  done
  HARNESS_SESSIONS="${HARNESS_SESSIONS:-${HARNESS_HOME}/sessions}"
  unset _cur
fi
HARNESS_MODEL="${HARNESS_MODEL:-}"
HARNESS_PROVIDER="${HARNESS_PROVIDER:-}"
HARNESS_MAX_TURNS="${HARNESS_MAX_TURNS:-100}"
HARNESS_LOG="${HARNESS_LOG:-/dev/stderr}"

# --------------------------------------------------------------------------- #
#  Source discovery                                                            #
# --------------------------------------------------------------------------- #
# Fully dynamic — called every loop iteration. Walks CWD upward collecting
# .harness/ dirs and bundled plugins. Provider plugins (dirs containing a
# providers/ subdir) are skipped if their basename != HARNESS_PROVIDER.

_HARNESS_SOURCES=()

_discover_sources() {
  _HARNESS_SOURCES=()

  # Bundled plugins (lowest priority)
  local d
  for d in "${HARNESS_ROOT}/plugins"/*/; do
    [[ -d "${d}" ]] || continue
    d="${d%/}"
    if [[ -d "${d}/providers" && "$(basename "${d}")" != "${HARNESS_PROVIDER}" ]]; then
      continue
    fi
    _HARNESS_SOURCES+=("${d}")
  done

  # Collect .harness/ dirs: CWD upward (most-local first)
  local harness_dirs=()
  local cur="${PWD}"
  while true; do
    [[ -d "${cur}/.harness" ]] && harness_dirs+=("${cur}/.harness")
    [[ "${cur}" == "/" ]] && break
    cur="$(dirname "${cur}")"
  done
  # Ensure ~/.harness always present
  local found=0
  for d in "${harness_dirs[@]:-}"; do
    [[ "${d}" == "${HARNESS_HOME}" ]] && found=1
  done
  (( found )) || harness_dirs+=("${HARNESS_HOME}")

  # Process global-first (reverse of harness_dirs)
  local i
  for (( i=${#harness_dirs[@]}-1; i>=0; i-- )); do
    local hd="${harness_dirs[i]}"
    for d in "${hd}/plugins"/*/; do
      [[ -d "${d}" ]] || continue
      d="${d%/}"
      if [[ -d "${d}/providers" && "$(basename "${d}")" != "${HARNESS_PROVIDER}" ]]; then
        continue
      fi
      _HARNESS_SOURCES+=("${d}")
    done
    _HARNESS_SOURCES+=("${hd}")
  done

  # Export colon-separated list for hooks
  local joined=""
  for d in "${_HARNESS_SOURCES[@]}"; do
    [[ -n "${joined}" ]] && joined+=":"
    joined+="${d}"
  done
  export HARNESS_SOURCES="${joined}"
}

# --------------------------------------------------------------------------- #
#  Hook runner                                                                 #
# --------------------------------------------------------------------------- #
# Hooks are executables in hooks.d/<stage>/ directories. They are collected
# from all sources (local overrides global by basename), sorted by numeric
# prefix, and run as a pipeline: each hook's stdout feeds the next hook's
# stdin. Non-zero exit aborts the chain.

run_hooks() {
  local stage="$1"; shift
  local extra_args=("$@")

  # Collect hooks from all sources (lowest to highest priority).
  # Later entries override earlier ones sharing the same basename.
  declare -A hook_map
  local order=()

  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    _collect_hooks_from "${src}/hooks.d/${stage}" hook_map order
  done

  # Sort by basename (numeric prefix gives order)
  mapfile -t sorted < <(printf '%s\n' "${order[@]}" | sort -t/ -k1,1)

  # Resolve back to full paths, deduplicated
  local hooks=()
  local seen=()
  for base in "${sorted[@]:-}"; do
    [[ -z "${base}" ]] && continue
    local dup=0
    for s in "${seen[@]:-}"; do [[ "$s" == "$base" ]] && dup=1; done
    (( dup )) && continue
    seen+=("$base")
    hooks+=("${hook_map[$base]}")
  done

  # Run the pipeline
  local current=""
  [[ ! -t 0 ]] && current="$(cat)"

  export HARNESS_SESSION="${SESSION_DIR:-}" HARNESS_STAGE="${stage}"
  export HARNESS_MODEL HARNESS_PROVIDER HARNESS_ROOT
  export HARNESS_LOG HARNESS_SOURCES

  for hook in "${hooks[@]:-}"; do
    [[ -z "${hook}" ]] && continue
    current="$(
      echo "${current}" | "${hook}" "${extra_args[@]}" 2>>"${HARNESS_LOG}"
    )"
    local rc=$?
    if (( rc != 0 )); then
      _log "hook ${hook} exited ${rc} during ${stage}"
      printf '%s' "${current}"
      return ${rc}
    fi
  done

  printf '%s' "${current}"
}

_collect_hooks_from() {
  local dir="$1"
  local -n map_ref="$2"
  local -n order_ref="$3"
  [[ -d "${dir}" ]] || return 0
  local f
  for f in "${dir}"/*; do
    [[ -x "${f}" ]] || continue
    local base="$(basename "${f}")"
    map_ref["${base}"]="${f}"
    local found=0
    for o in "${order_ref[@]:-}"; do [[ "$o" == "$base" ]] && found=1; done
    (( found )) || order_ref+=("${base}")
  done
}

# --------------------------------------------------------------------------- #
#  Main agent loop — pure state follower                                      #
# --------------------------------------------------------------------------- #
agent_loop() {
  local session_dir="$1"
  export SESSION_DIR="${session_dir}"
  local state="start" context='{}' result="" rc=0 iterations=0

  while [[ -n "${state}" ]]; do
    _discover_sources
    result="" rc=0
    result="$(echo "${context}" | run_hooks "${state}")" && rc=0 || rc=$?

    if (( rc != 0 )); then
      [[ "${state}" == "error" ]] && break
      state="error"; context="${result}"; continue
    fi

    state="$(echo "${result}" | jq -r '.next_state // empty' 2>/dev/null)" || true
    context="$(echo "${result}" | jq -c 'del(.next_state)' 2>/dev/null)" || context='{}'
    [[ -z "${context}" || "${context}" == "null" ]] && context='{}'

    # Safety valve
    iterations=$((iterations + 1))
    if (( iterations > HARNESS_MAX_TURNS * 3 )); then
      _log "safety: exceeded max iterations"; break
    fi
  done

  # Print output from terminal state
  local output
  output="$(echo "${result:-}" | jq -r '.output // empty' 2>/dev/null)" || true
  [[ -n "${output}" ]] && printf '%s\n' "${output}"
}

# --------------------------------------------------------------------------- #
#  Utilities                                                                   #
# --------------------------------------------------------------------------- #
_log() {
  echo "[harness] $*" >> "${HARNESS_LOG}"
}

_die() {
  echo "harness: $*" >&2
  exit 1
}

_require() {
  command -v "$1" &>/dev/null || _die "required command '$1' not found"
}

# --------------------------------------------------------------------------- #
#  Command discovery                                                           #
# --------------------------------------------------------------------------- #
# Commands are executables in commands/ directories within plugin sources.
# Protocol: --describe returns one-line help text; otherwise executed with args.
# Discovery follows the same source walk as tools/hooks: local overrides global.

_find_command() {
  local target="$1"
  local result=""
  local src
  for src in "${_HARNESS_SOURCES[@]}"; do
    local f="${src}/commands/${target}"
    [[ -x "$f" && -f "$f" ]] && result="$f"
  done
  echo "${result}"
}

# --------------------------------------------------------------------------- #
#  CLI                                                                         #
# --------------------------------------------------------------------------- #
main() {
  _require jq
  _require curl
  mkdir -p "${HARNESS_HOME}" "${HARNESS_SESSIONS}"
  _discover_sources

  # Export env vars so command scripts inherit them
  export HARNESS_ROOT HARNESS_HOME HARNESS_SESSIONS HARNESS_PROVIDER
  export HARNESS_MODEL HARNESS_MAX_TURNS HARNESS_LOG HARNESS_VERSION

  local cmd="${1:-agent}"
  case "${cmd}" in --help|-h) cmd="help" ;; --version|-v) cmd="version" ;; esac

  local cmd_path
  cmd_path="$(_find_command "${cmd}")"
  if [[ -n "${cmd_path}" ]]; then
    shift || true
    exec "${cmd_path}" "$@"
  else
    # Not a known command — treat entire args as message to agent
    cmd_path="$(_find_command "agent")"
    [[ -n "${cmd_path}" ]] || _die "no agent command found"
    exec "${cmd_path}" "$@"
  fi
}

# Only run main when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
