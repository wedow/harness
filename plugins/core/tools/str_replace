#!/usr/bin/env bash
# str_replace — tool plugin: replace a unique string in a file.
set -euo pipefail

case "${1:-}" in
  --schema)
    cat <<'JSON'
{
  "name": "str_replace",
  "description": "Replace a unique string in a file with another string. The old_str must appear exactly once in the file. Use for targeted edits without rewriting the entire file.",
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the file"
      },
      "old_str": {
        "type": "string",
        "description": "Exact string to find (must be unique in the file)"
      },
      "new_str": {
        "type": "string",
        "description": "Replacement string (empty string to delete)"
      },
      "replace_all": {
        "type": "boolean",
        "description": "Replace all occurrences instead of requiring uniqueness (default: false)"
      }
    },
    "required": ["path", "old_str", "new_str"]
  }
}
JSON
    ;;
  --describe)
    echo "Replace a unique string in a file"
    ;;
  --exec)
    input="$(cat)"
    path="$(echo "${input}" | jq -r '.path')"
    old_str="$(echo "${input}" | jq -r '.old_str')"
    new_str="$(echo "${input}" | jq -r '.new_str')"
    replace_all="$(echo "${input}" | jq -r '.replace_all // false')"

    if [[ "${path}" != /* ]]; then
      path="${HARNESS_CWD:-${PWD}}/${path}"
    fi

    if [[ ! -f "${path}" ]]; then
      echo "error: file not found: ${path}"
      exit 1
    fi

    # Count occurrences (grep -c counts lines, not matches; use grep -oF | wc -l)
    count="$(grep -oF "${old_str}" "${path}" 2>/dev/null | wc -l)" || count=0
    if (( count == 0 )); then
      echo "error: old_str not found in ${path}"
      exit 1
    fi
    if [[ "${replace_all}" != "true" ]] && (( count > 1 )); then
      echo "error: old_str appears ${count} times in ${path} (must be unique; use replace_all to replace all)"
      exit 1
    fi

    # Perform replacement using perl for reliable multi-line handling
    # Single-quoted script body prevents bash expansion; env vars pass data safely
    perl_flag="s"
    [[ "${replace_all}" == "true" ]] && perl_flag="sg"
    OLD_STR="${old_str}" NEW_STR="${new_str}" PERL_FLAG="${perl_flag}" perl -i -0pe '
      my $old = quotemeta($ENV{OLD_STR});
      my $new = $ENV{NEW_STR};
      my $flag = $ENV{PERL_FLAG};
      if ($flag eq "sg") { s/$old/$new/sg; }
      else               { s/$old/$new/s;  }
    ' "${path}" 2>/dev/null || {
      # Fallback: python if perl isn't available
      py_count="1"
      [[ "${replace_all}" == "true" ]] && py_count="-1"
      HARNESS_FILE_PATH="${path}" OLD_STR="${old_str}" NEW_STR="${new_str}" PY_COUNT="${py_count}" python3 -c '
import os
p = os.environ["HARNESS_FILE_PATH"]
old = os.environ["OLD_STR"]
new = os.environ["NEW_STR"]
count = int(os.environ["PY_COUNT"])
with open(p) as f: content = f.read()
content = content.replace(old, new) if count < 0 else content.replace(old, new, count)
with open(p, "w") as f: f.write(content)
' 2>/dev/null || {
        echo "error: replacement failed (need perl or python3)"
        exit 1
      }
    }

    if [[ "${replace_all}" == "true" ]]; then
      echo "replaced ${count} occurrences in ${path}"
    else
      echo "replaced in ${path}"
    fi
    ;;
  *)
    echo "usage: str_replace --schema | --describe | --exec" >&2
    exit 1
    ;;
esac
