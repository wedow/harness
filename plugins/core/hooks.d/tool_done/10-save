#!/usr/bin/env bash
# 10-save — save a tool result and route to next tool or back to assemble.
# Receives JSON: {call_id, name, input, result, error, tool_calls: [...]}.
# Emits: {next_state: "tool_exec", tool_calls: [...]} if more remain,
#        {next_state: "assemble"} if done.
set -euo pipefail

data="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"
[[ -d "${msg_dir}" ]] || exit 0

# Next sequence number
last="$(ls -1 "${msg_dir}/" 2>/dev/null | sort -n | tail -1)"
if [[ -z "${last}" ]]; then
  seq="0001"
else
  seq="$(printf '%04d' $(( 10#${last%%-*} + 1 )))"
fi

call_id="$(echo "${data}" | jq -r '.call_id')"
tool="$(echo "${data}" | jq -r '.name')"
error="$(echo "${data}" | jq -r '.error')"
result="$(echo "${data}" | jq -r '.result')"

cat > "${msg_dir}/${seq}-tool_result.md" <<EOF
---
role: tool_result
seq: ${seq}
timestamp: $(date -Iseconds)
call_id: ${call_id}
tool: ${tool}
error: ${error}
---
${result}
EOF

# Route: more tool calls remaining → tool_exec, otherwise → assemble
remaining="$(echo "${data}" | jq -c '.tool_calls')"
if [[ "$(echo "${remaining}" | jq 'length')" -gt 0 ]]; then
  jq -n --argjson tool_calls "${remaining}" '{next_state: "tool_exec", tool_calls: $tool_calls}'
else
  echo '{"next_state": "assemble"}'
fi
