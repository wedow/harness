#!/usr/bin/env bash
# 35-skills — discover skills and inject catalog into the system prompt.
# Runs AFTER 30-prompts so the catalog is appended to a fully-built system
# prompt rather than getting clobbered by 30-prompts replacing the field.
#
# Walks CWD upward (like source discovery) collecting skills from:
#   <dir>/.harness/skills/    (harness-native)
#   <dir>/.agents/skills/     (cross-client convention)
#
# Each skill is a directory containing a SKILL.md with YAML frontmatter.
# Only name + description are loaded here (tier 1: catalog).
set -euo pipefail

payload="$(cat)"

# Collect skill directories: CWD upward, global first (lowest priority)
skill_dirs=()

# Bundled plugin skills (lowest priority — added first so any local override wins).
# Iterates HARNESS_SOURCES looking for skills/ in plugin source dirs (e.g.
# plugins/core/skills/). Skips .harness/ dirs themselves; those are handled
# by the CWD-walk below.
IFS=':' read -ra _src_arr <<< "${HARNESS_SOURCES:-}"
for _src in "${_src_arr[@]}"; do
  case "${_src}" in */.harness) continue ;; esac
  [[ "${_src}" == "${HARNESS_HOME:-}" ]] && continue
  [[ -d "${_src}/skills" ]] && skill_dirs+=("${_src}/skills")
done

walk_dirs=()
cur="${HARNESS_CWD:-${PWD}}"
while true; do
  walk_dirs+=("${cur}")
  [[ "${cur}" == "/" ]] && break
  cur="$(dirname "${cur}")"
done
# Ensure ~ is included
home_found=0
for d in "${walk_dirs[@]}"; do
  [[ "${d}" == "${HOME}" ]] && home_found=1
done
(( home_found )) || walk_dirs+=("${HOME}")

# Reverse to process global first
for (( i=${#walk_dirs[@]}-1; i>=0; i-- )); do
  d="${walk_dirs[i]}"
  [[ -d "${d}/.harness/skills" ]] && skill_dirs+=("${d}/.harness/skills")
  [[ -d "${d}/.agents/skills" ]]  && skill_dirs+=("${d}/.agents/skills")
done

# Discover skills: name → {description, path}, last wins (most-local)
declare -A skill_names skill_descs skill_paths
for sdir in "${skill_dirs[@]}"; do
  for candidate in "${sdir}"/*/; do
    [[ -d "${candidate}" ]] || continue
    skillmd="${candidate}SKILL.md"
    [[ -f "${skillmd}" ]] || continue

    # Extract YAML frontmatter (between first and second ---)
    frontmatter="$(awk '/^---$/{n++; next} n==1{print} n>=2{exit}' "${skillmd}")"
    [[ -z "${frontmatter}" ]] && continue

    name="$(echo "${frontmatter}" | grep -m1 '^name:' | sed 's/^name:[[:space:]]*//')"
    desc="$(echo "${frontmatter}" | grep -m1 '^description:' | sed 's/^description:[[:space:]]*//')"
    [[ -z "${name}" || -z "${desc}" ]] && continue

    skill_names["${name}"]=1
    skill_descs["${name}"]="${desc}"
    skill_paths["${name}"]="$(cd "$(dirname "${skillmd}")" && pwd)/SKILL.md"
  done
done

# No skills? Pass through unchanged.
if [[ ${#skill_names[@]} -eq 0 ]]; then
  echo "${payload}"
  exit 0
fi

# Build catalog block
catalog="<available-skills>"
for name in $(printf '%s\n' "${!skill_names[@]}" | sort); do
  catalog+=$'\n'"  <skill name=\"${name}\" path=\"${skill_paths[${name}]}\">"
  catalog+=$'\n'"    ${skill_descs[${name}]}"
  catalog+=$'\n'"  </skill>"
done
catalog+=$'\n'"</available-skills>"

instructions="The skills below are authoritative guides for specific task types. BEFORE doing anything else on a user request, scan these descriptions; if any matches the request, call the \`skill\` tool with that name FIRST to load its full instructions, and follow them. Do not improvise or explore the codebase to figure out something a skill already covers."

block="${instructions}"$'\n\n'"${catalog}"

# Append to existing system prompt
printf '%s\n%s' "${payload}" "$(printf '%s' "${block}" | jq -Rs '.')" \
  | jq -s '.[0] + {system: (.[0].system + "\n\n" + .[1])}'
