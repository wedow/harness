#!/usr/bin/env bash
# chatgpt — provider plugin for the ChatGPT Responses API with OAuth auth.
# Receives assembled payload JSON on stdin, outputs the API response.
set -euo pipefail

[[ "${1:-}" == "--describe" ]] && { echo "ChatGPT Responses API (OAuth)"; exit 0; }
[[ "${1:-}" == "--ready" ]] && {
  cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
  [[ -f "${cache}" ]] || exit 1
  jq -e '.chatgpt | length > 0' "${cache}" &>/dev/null || exit 1
  exp="$(jq -r '.chatgpt[0].expires_at // "0"' "${cache}")"
  [[ "${exp}" == "0" ]] || [[ "$(date +%s)" -lt "${exp}" ]]
  exit $?
}
[[ "${1:-}" == "--defaults" ]] && { echo "model=gpt-5.4"; exit 0; }
[[ "${1:-}" == "--env" ]] && { cat <<'ENVEOF'
CHATGPT_MODEL       model override (gpt-5.4)
ENVEOF
exit 0; }

_stream=false
[[ "${1:-}" == "--stream" ]] && { _stream=true; shift; }

cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
[[ -f "${cache}" ]] || { echo "no auth cache — run: hs auth set chatgpt" >&2; exit 1; }

# Read credentials
access_token="$(jq -r '.chatgpt[0].access_token // empty' "${cache}")"
refresh_token="$(jq -r '.chatgpt[0].refresh_token // empty' "${cache}")"
id_token="$(jq -r '.chatgpt[0].id_token // empty' "${cache}")"
account_id="$(jq -r '.chatgpt[0].account_id // empty' "${cache}")"
expires_at="$(jq -r '.chatgpt[0].expires_at // "0"' "${cache}")"

[[ -z "${access_token}" ]] && { echo "no chatgpt access_token — run: hs auth set chatgpt" >&2; exit 1; }

# Refresh token if expired
now="$(date +%s)"
if [[ -n "${refresh_token}" && "${expires_at}" != "0" && "${now}" -ge "${expires_at}" ]]; then
  token_response="$(curl -sS -X POST "https://auth.openai.com/oauth/token" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "grant_type=refresh_token" \
    -d "refresh_token=${refresh_token}" \
    -d "client_id=app_EMoamEEZ73f0CkXaXp7hrann" \
    --max-time 30)" || { echo "token refresh failed" >&2; exit 1; }

  new_access="$(echo "${token_response}" | jq -r '.access_token // empty')"
  [[ -z "${new_access}" ]] && {
    echo "token refresh failed ($(echo "${token_response}" | jq -r '.error_description // .error.message // .error // "unknown"' 2>/dev/null)) — run: hs auth set chatgpt" >&2
    exit 1
  }

  new_refresh="$(echo "${token_response}" | jq -r '.refresh_token // empty')"
  new_id_token="$(echo "${token_response}" | jq -r '.id_token // empty')"
  expires_in="$(echo "${token_response}" | jq -r '.expires_in // "0"')"

  new_expires_at="0"
  if [[ "${expires_in}" != "0" && "${expires_in}" != "null" ]]; then
    new_expires_at="$(( $(date +%s) + expires_in - 300 ))"
  fi

  # Fall back to id_token JWT expiry if expires_in is unavailable.
  if [[ "${new_expires_at}" == "0" && -n "${new_id_token}" && "${new_id_token}" != "null" ]]; then
    jwt_payload="$(echo "${new_id_token}" | cut -d. -f2 | sed 'y|-_|+/|' | awk '{while(length%4)$0=$0"=";print}' | base64 -d 2>/dev/null)" || true
    if [[ -n "${jwt_payload}" ]]; then
      new_expires_at="$(echo "${jwt_payload}" | jq -r '.exp // "0"' 2>/dev/null)" || new_expires_at="0"
    fi
  fi

  access_token="${new_access}"
  [[ -n "${new_refresh}" && "${new_refresh}" != "null" ]] && refresh_token="${new_refresh}"
  [[ -n "${new_id_token}" && "${new_id_token}" != "null" ]] && id_token="${new_id_token}"

  # Update source .auth.json so the next auth-cache rebuild keeps the refresh.
  IFS=':' read -ra _auth_sources <<< "${HARNESS_SOURCES}"
  auth_file=""
  for _s in "${_auth_sources[@]}"; do
    [[ -f "${_s}/.auth.json" ]] && jq -e '.chatgpt | length > 0' "${_s}/.auth.json" &>/dev/null && auth_file="${_s}/.auth.json"
  done
  if [[ -n "${auth_file}" ]]; then
    updated="$(jq \
      --arg at "${access_token}" \
      --arg rt "${refresh_token}" \
      --arg it "${id_token}" \
      --arg exp "${new_expires_at}" \
      '.chatgpt[0].access_token = $at
       | .chatgpt[0].refresh_token = $rt
       | .chatgpt[0].id_token = $it
       | .chatgpt[0].expires_at = $exp' "${auth_file}")"
    _tmp="$(mktemp "${auth_file}.XXXXXX")"
    echo "${updated}" > "${_tmp}" && chmod 600 "${_tmp}" && mv -f "${_tmp}" "${auth_file}"
  fi

  # Update auth cache for this run.
  updated="$(jq \
    --arg at "${access_token}" \
    --arg rt "${refresh_token}" \
    --arg it "${id_token}" \
    --arg exp "${new_expires_at}" \
    '.chatgpt[0].access_token = $at
     | .chatgpt[0].refresh_token = $rt
     | .chatgpt[0].id_token = $it
     | .chatgpt[0].expires_at = $exp' "${cache}")"
  _tmp="$(mktemp "${cache}.XXXXXX")"
  echo "${updated}" > "${_tmp}" && chmod 600 "${_tmp}" && mv -f "${_tmp}" "${cache}"
  echo "refreshed chatgpt token" >&2
fi

payload="$(cat)"

model="$(echo "${payload}" | jq -r '.model // ""')"
[[ -z "${model}" ]] && model="${HARNESS_MODEL}"

system="$(echo "${payload}" | jq -r '.system // ""')"
input_items="$(echo "${payload}" | jq -c '.messages // []')"
tools="$(echo "${payload}" | jq -c '.tools // []')"

# Translate tool schemas: canonical (name/description/input_schema) → Responses API format
responses_tools="$(echo "${tools}" | jq -c '[.[] | {
  type: "function",
  name: .name,
  description: .description,
  parameters: .input_schema
}]')"

# Build the request
request="$(echo "${input_items}" | jq -c \
  --arg model "${model}" \
  --arg instructions "${system}" \
  --argjson tools "${responses_tools}" \
  '{model: $model, instructions: $instructions, input: ., store: false, stream: true}
   | if ($tools | length) > 0 then . + {tools: $tools} else . end'
)"

# Add reasoning if HARNESS_THINKING is set
if [[ -n "${HARNESS_THINKING:-}" && "${HARNESS_THINKING}" != "off" ]]; then
  _re="${HARNESS_THINKING}"
  [[ "${_re}" == "max" ]] && _re="high"
  request="$(echo "${request}" | jq -c --arg effort "${_re}" '. + {reasoning: {effort: $effort}}')"
fi

if [[ "${_stream}" == true ]]; then
  # Streaming path: display text deltas in real-time, extract final response
  response=""
  stream_text=""
  non_sse_body=""
  declare -A _fc_names=() _fc_ids=() _fc_args=()
  while IFS= read -r line || [[ -n "${line}" ]]; do
    if [[ "${line}" != data:* ]]; then
      [[ -n "${line}" ]] && non_sse_body+="${line}"$'\n'
      continue
    fi
    data="${line#data: }"
    type="$(echo "${data}" | jq -r '.type // empty' 2>/dev/null)" || continue
    case "${type}" in
      response.output_text.delta)
        delta="$(echo "${data}" | jq -j '.delta // empty'; printf x)"
        delta="${delta%x}"
        stream_text+="${delta}"
        [[ -n "${delta}" && -n "${HARNESS_SESSION:-}" ]] && printf '%s\n' "$(jq -c -n --arg t "${delta}" '{type:"text",text:$t}')" >> "${HARNESS_SESSION}/.stream"
        ;;
      response.output_item.added)
        _item_type="$(echo "${data}" | jq -r '.item.type // empty')"
        if [[ "${_item_type}" == "function_call" ]]; then
          _oi="$(echo "${data}" | jq -r '.output_index')"
          _fc_names["${_oi}"]="$(echo "${data}" | jq -r '.item.name // empty')"
          _fc_ids["${_oi}"]="$(echo "${data}" | jq -r '.item.call_id // empty')"
        fi
        ;;
      response.function_call_arguments.done)
        _oi="$(echo "${data}" | jq -r '.output_index')"
        _args="$(echo "${data}" | jq -r '.arguments // "{}"')"
        _fc_args["${_oi}"]="${_args}"
        _parsed="$(echo "${_args}" | jq -c '.' 2>/dev/null || echo '{}')"
        if [[ -n "${HARNESS_TOOL_FIFO:-}" ]]; then
          jq -c -n --arg id "${_fc_ids[${_oi}]:-}" --arg name "${_fc_names[${_oi}]:-}" \
            --argjson input "${_parsed}" \
            '{id: $id, name: $name, input: $input}' > "${HARNESS_TOOL_FIFO}"
        fi
        [[ -n "${HARNESS_SESSION:-}" ]] && printf '%s\n' "$(jq -c -n --arg id "${_fc_ids[${_oi}]:-}" --arg name "${_fc_names[${_oi}]:-}" --argjson input "${_parsed}" '{type:"tool_start",id:$id,name:$name,input:$input}')" >> "${HARNESS_SESSION}/.stream"
        ;;
      response.completed)
        response="$(echo "${data}" | jq -c '.response')"
        ;;
    esac
  done < <(echo "${request}" | curl -sS -N "https://chatgpt.com/backend-api/codex/responses" \
    -H "Authorization: Bearer ${access_token}" \
    -H "ChatGPT-Account-ID: ${account_id}" \
    -H "Content-Type: application/json" \
    -d @- \
    --max-time 300
  )

  if [[ -z "${response}" ]]; then
    err_msg="$(printf '%s' "${non_sse_body}" | jq -r '.error.message // .detail // empty' 2>/dev/null)"
    if [[ -n "${err_msg}" ]]; then
      err_resets="$(printf '%s' "${non_sse_body}" | jq -r '.error.resets_in_seconds // empty' 2>/dev/null)"
      [[ -n "${err_resets}" ]] && err_msg+=" (resets in ${err_resets}s)"
      echo "chatgpt API error: ${err_msg}" >&2
    else
      echo "no response.completed event in stream" >&2
      [[ -n "${non_sse_body}" ]] && { _bd="${non_sse_body%$'\n'}"; echo "body: ${_bd:0:500}" >&2; }
    fi
    exit 1
  fi

  stream_output="[]"
  if [[ -n "${stream_text}" ]]; then
    stream_output="$(printf '%s' "${stream_text}" | jq -Rs \
      '[{type: "message", role: "assistant", content: [{type: "output_text", text: .}]}]')"
  fi

  if [[ ${#_fc_ids[@]} -gt 0 ]]; then
    for _oi in $(echo "${!_fc_ids[@]}" | tr ' ' '\n' | sort -n); do
      _stream_args="${_fc_args[${_oi}]:-}"
      [[ -n "${_stream_args}" ]] || _stream_args='{}'
      stream_output="$(echo "${stream_output}" | jq -c \
        --arg id "${_fc_ids[${_oi}]}" \
        --arg name "${_fc_names[${_oi}]}" \
        --arg arguments "${_stream_args}" \
        '. + [{type: "function_call", call_id: $id, name: $name, arguments: $arguments}]'
      )"
    done
  fi

  if [[ "$(echo "${stream_output}" | jq 'length')" -gt 0 ]]; then
    response="$(printf '%s\n%s' "${response}" "${stream_output}" | jq -c -s '
      .[0] as $response
      | .[1] as $stream_output
      | ($response.output // []) as $existing
      | ($existing | map(select(.type == "function_call")) | map(.call_id)) as $existing_call_ids
      | ($existing | map(.type == "message") | any) as $has_message
      | ($stream_output
          | map(
              if .type == "message" then
                select($has_message | not)
              elif .type == "function_call" then
                select((.call_id as $id | $existing_call_ids | index($id)) | not)
              else
                empty
              end
            )
        ) as $missing
      | if ($existing | length) == 0 then
          $response + {output: $stream_output}
        elif ($missing | length) > 0 then
          $response + {output: ($existing + $missing)}
        else
          $response
        end'
    )"
  fi

  echo "${response}"
  exit 0
fi

# Non-streaming path: buffer all SSE output and extract final response
sse_output="$(echo "${request}" | curl -sS "https://chatgpt.com/backend-api/codex/responses" \
  -H "Authorization: Bearer ${access_token}" \
  -H "ChatGPT-Account-ID: ${account_id}" \
  -H "Content-Type: application/json" \
  -d @- \
  --max-time 300
)"

# Check for non-SSE error responses (plain JSON)
if echo "${sse_output}" | jq -e '.error // .detail' &>/dev/null 2>&1; then
  error_msg="$(echo "${sse_output}" | jq -r '.error.message // .detail // "unknown error"' 2>/dev/null)"
  echo "chatgpt API error: ${error_msg}" >&2
  exit 1
fi

# Parse SSE: extract the response object from the response.completed event
response="$(echo "${sse_output}" | grep '^data: ' | sed 's/^data: //' | \
  jq -c 'select(.type == "response.completed") | .response' 2>/dev/null | tail -1)"

if [[ -z "${response}" ]]; then
  echo "no response.completed event in stream" >&2
  exit 1
fi

echo "${response}"
