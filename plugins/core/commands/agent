#!/usr/bin/env bash
# agent — run the agent (interactive or one-shot)
set -euo pipefail

case "${1:-}" in --describe) echo "run the agent (interactive or one-shot)"; exit 0 ;; esac

source "${HARNESS_ROOT}/bin/harness"

# --- Provider resolution ---

_resolve_provider() {
  # With HARNESS_PROVIDER empty, sources hooks include all provider plugins
  _refresh_sources
  if [[ -z "${HARNESS_PROVIDER}" ]]; then
    local src f name
    for src in "${_HARNESS_SOURCES[@]}"; do
      [[ -d "${src}/providers" ]] || continue
      for f in "${src}/providers"/*; do
        if [[ -x "$f" ]]; then
          name="$(basename "$f")"
          if "$f" --ready 2>/dev/null; then
            HARNESS_PROVIDER="${name}"
            break 2
          fi
        elif [[ "$f" == *.conf ]]; then
          name="$(basename "$f" .conf)"
          # Variant ready: auth_env set or auth cache entry
          local ae; ae="$(grep '^auth_env=' "$f" | head -1 | cut -d= -f2-)"
          if [[ -n "${ae}" && -n "${!ae:-}" ]]; then
            HARNESS_PROVIDER="${name}"; break 2
          fi
          local cache="${HARNESS_HOME}/.auth-cache.json"
          if [[ -f "${cache}" ]] && jq -e ".\"${name}\" | length > 0" "${cache}" &>/dev/null; then
            HARNESS_PROVIDER="${name}"; break 2
          fi
        fi
      done
    done
  fi
  [[ -z "${HARNESS_PROVIDER}" ]] && return 0

  # Get defaults — variant conf or provider binary
  local conf_file="" i
  for (( i=${#_HARNESS_SOURCES[@]}-1; i>=0; i-- )); do
    [[ -f "${_HARNESS_SOURCES[i]}/providers/${HARNESS_PROVIDER}.conf" ]] && {
      conf_file="${_HARNESS_SOURCES[i]}/providers/${HARNESS_PROVIDER}.conf"
      break
    }
  done

  if [[ -n "${conf_file}" ]]; then
    local model_val
    model_val="$(grep '^model=' "${conf_file}" | head -1 | cut -d= -f2-)"
    [[ -n "${model_val}" && -z "${HARNESS_MODEL}" ]] && HARNESS_MODEL="${model_val}"
  else
    local provider_path=""
    for (( i=${#_HARNESS_SOURCES[@]}-1; i>=0; i-- )); do
      [[ -x "${_HARNESS_SOURCES[i]}/providers/${HARNESS_PROVIDER}" ]] && {
        provider_path="${_HARNESS_SOURCES[i]}/providers/${HARNESS_PROVIDER}"
        break
      }
    done
    [[ -z "${provider_path}" ]] && return 0
    local key val
    while IFS='=' read -r key val; do
      [[ -z "${key}" ]] && continue
      case "${key}" in
        model) [[ -z "${HARNESS_MODEL}" ]] && HARNESS_MODEL="${val}" ;;
      esac
    done < <("${provider_path}" --defaults 2>/dev/null || true)
  fi
}

# --- Session helpers (inlined, private) ---

_new_session() {
  local id; id="$(date +%Y%m%d-%H%M%S)-$$"
  local dir="${HARNESS_SESSIONS}/${id}"
  mkdir -p "${dir}/messages"
  cat > "${dir}/session.conf" <<EOF
id=${id}
model=${HARNESS_MODEL}
provider=${HARNESS_PROVIDER}
created=$(date -Iseconds)
cwd=${PWD}
EOF
  echo "${dir}"
}

_next_seq() {
  local dir="$1"
  local last; last="$(ls -1 "${dir}/messages/" 2>/dev/null | sort -n | tail -1)"
  if [[ -z "${last}" ]]; then echo "0001"
  else printf '%04d' $(( 10#${last%%-*} + 1 )); fi
}

_save_message() {
  local dir="$1" content="$2"
  local seq; seq="$(_next_seq "${dir}")"
  cat > "${dir}/messages/${seq}-user.md" <<EOF
---
role: user
seq: ${seq}
timestamp: $(date -Iseconds)
---
${content}
EOF
}

# --- Main ---

_resolve_provider

# Determine mode
session_dir=""
message=""
mode=""

if [[ -n "${1:-}" && -d "${HARNESS_SESSIONS}/${1}" ]]; then
  # Resume existing session
  session_dir="${HARNESS_SESSIONS}/${1}"
  shift
  if (( $# > 0 )); then
    message="$*"
    mode="oneshot"
  elif [[ ! -t 0 ]]; then
    message="$(cat)"
    mode="oneshot"
  else
    mode="repl"
  fi
elif (( $# > 0 )); then
  # One-shot with args
  message="$*"
  mode="oneshot"
elif [[ ! -t 0 ]]; then
  # One-shot from stdin
  message="$(cat)"
  mode="oneshot"
else
  # Interactive REPL, new session
  mode="repl"
fi

# Create session if needed
if [[ -z "${session_dir}" ]]; then
  session_dir="$(_new_session)"
  echo "session: $(basename "${session_dir}")" >&2
  [[ -n "${HARNESS_PROVIDER}" ]] && echo "provider: ${HARNESS_PROVIDER}" >&2
  [[ -n "${HARNESS_MODEL}" ]] && echo "model: ${HARNESS_MODEL}" >&2
fi

# One-shot
if [[ "${mode}" == "oneshot" ]]; then
  _save_message "${session_dir}" "${message}"
  agent_loop "${session_dir}"
  exit 0
fi

# REPL
while true; do
  printf '\n\033[1;36mYou:\033[0m '
  IFS= read -r input || break
  [[ -z "${input}" ]] && continue
  [[ "${input}" == "/quit" || "${input}" == "/exit" ]] && break
  [[ "${input}" == "/session" ]] && { echo "${session_dir}"; continue; }

  _save_message "${session_dir}" "${input}"
  printf '\033[1;33mAgent:\033[0m '
  agent_loop "${session_dir}"
  echo
done
