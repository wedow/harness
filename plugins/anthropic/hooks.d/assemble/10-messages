#!/usr/bin/env bash
# 10-messages — read canonical session files, produce Anthropic messages array.
# Pipeline hook: receives partial payload on stdin, adds "messages" field.
set -euo pipefail

payload="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"

[[ -d "${msg_dir}" ]] || { echo "${payload}"; exit 0; }

messages="[]"
tool_results="[]"

flush_tool_results() {
  if [[ "${tool_results}" != "[]" ]]; then
    local msg
    msg="$(jq -n --argjson content "${tool_results}" '{role: "user", content: $content}')"
    messages="$(echo "${messages}" | jq --argjson m "${msg}" '. + [$m]')"
    tool_results="[]"
  fi
}

for f in $(ls -1 "${msg_dir}"/*.md 2>/dev/null | sort); do
  _role=""
  _call_id=""
  _error="false"
  in_fm=false
  fm_done=false
  body=""
  while IFS= read -r line; do
    if [[ "${line}" == "---" ]] && ! ${fm_done}; then
      if ${in_fm}; then in_fm=false; fm_done=true; continue
      else in_fm=true; continue; fi
    fi
    if ${in_fm}; then
      case "${line}" in
        role:*)     _role="${line#role: }" ;;
        call_id:*)  _call_id="${line#call_id: }" ;;
        error:*)    _error="${line#error: }" ;;
      esac
    else
      body+="${line}"$'\n'
    fi
  done < "${f}"
  body="${body%$'\n'}"

  case "${_role}" in
    user)
      flush_tool_results
      msg="$(jq -n --arg content "${body}" '{role: "user", content: $content}')"
      messages="$(echo "${messages}" | jq --argjson m "${msg}" '. + [$m]')"
      ;;
    assistant)
      flush_tool_results
      content_blocks="[]"
      current_text=""
      in_tool_block=false
      in_thinking_block=false
      tool_id="" tool_name="" tool_body=""
      thinking_sig="" thinking_text=""

      _flush_text() {
        if [[ -n "${current_text}" ]]; then
          local _flush="${current_text%$'\n'}"
          local _flush_trimmed="${_flush//[$'\n\t ']/}"
          if [[ -n "${_flush_trimmed}" ]]; then
            content_blocks="$(echo "${content_blocks}" | jq --arg t "${_flush}" \
              '. + [{type: "text", text: $t}]')"
          fi
          current_text=""
        fi
      }

      while IFS= read -r line; do
        if [[ "${line}" =~ ^\`\`\`thinking\ signature=(.+) ]]; then
          _flush_text
          in_thinking_block=true
          thinking_sig="${BASH_REMATCH[1]}"
          thinking_text=""
          continue
        fi
        if ${in_thinking_block} && [[ "${line}" == '```' ]]; then
          in_thinking_block=false
          thinking_text="${thinking_text%$'\n'}"
          content_blocks="$(echo "${content_blocks}" | jq \
            --arg thinking "${thinking_text}" --arg signature "${thinking_sig}" \
            '. + [{type: "thinking", thinking: $thinking, signature: $signature}]')"
          continue
        fi
        if [[ "${line}" =~ ^\`\`\`tool_call\ id=([^ ]+)\ name=([^ ]+) ]]; then
          _flush_text
          in_tool_block=true
          tool_id="${BASH_REMATCH[1]}"
          tool_name="${BASH_REMATCH[2]}"
          tool_body=""
          continue
        fi
        if ${in_tool_block} && [[ "${line}" == '```' ]]; then
          in_tool_block=false
          content_blocks="$(echo "${content_blocks}" | jq \
            --arg id "${tool_id}" --arg name "${tool_name}" --argjson input "${tool_body}" \
            '. + [{type: "tool_use", id: $id, name: $name, input: $input}]')"
          continue
        fi
        if ${in_thinking_block}; then
          thinking_text+="${line}"$'\n'
        elif ${in_tool_block}; then
          tool_body+="${line}"
        else
          current_text+="${line}"$'\n'
        fi
      done <<< "${body}"

      _flush_text

      block_count="$(echo "${content_blocks}" | jq 'length')"
      if (( block_count == 1 )) && [[ "$(echo "${content_blocks}" | jq -r '.[0].type')" == "text" ]]; then
        msg="$(echo "${content_blocks}" | jq '{role: "assistant", content: .[0].text}')"
      else
        msg="$(echo "${content_blocks}" | jq '{role: "assistant", content: .}')"
      fi
      messages="$(echo "${messages}" | jq --argjson m "${msg}" '. + [$m]')"
      ;;
    tool_result)
      if [[ "${_error}" == "true" ]]; then
        tr="$(jq -n --arg id "${_call_id}" --arg content "${body}" \
          '{type: "tool_result", tool_use_id: $id, content: $content, is_error: true}')"
      else
        tr="$(jq -n --arg id "${_call_id}" --arg content "${body}" \
          '{type: "tool_result", tool_use_id: $id, content: $content}')"
      fi
      tool_results="$(echo "${tool_results}" | jq --argjson tr "${tr}" '. + [$tr]')"
      ;;
  esac
done

flush_tool_results
echo "${payload}" | jq --argjson msgs "${messages}" '. + {messages: $msgs}'
