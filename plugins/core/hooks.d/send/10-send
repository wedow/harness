#!/usr/bin/env bash
# 10-send — call the active provider with the assembled payload.
# On failure, outputs error JSON on stdout so the error state can display it.
set -euo pipefail

payload="$(cat)"

IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"

_find_bin() {
  local name="$1" i
  for (( i=${#sources[@]}-1; i>=0; i-- )); do
    [[ -x "${sources[i]}/providers/${name}" ]] && { echo "${sources[i]}/providers/${name}"; return; }
  done
  return 0
}

_find_conf() {
  local name="$1" i
  for (( i=${#sources[@]}-1; i>=0; i-- )); do
    [[ -f "${sources[i]}/providers/${name}.conf" ]] && { echo "${sources[i]}/providers/${name}.conf"; return; }
  done
  return 0
}

_find_tool() {
  local name="$1" i
  for (( i=${#sources[@]}-1; i>=0; i-- )); do
    [[ -x "${sources[i]}/tools/${name}" ]] && { echo "${sources[i]}/tools/${name}"; return; }
  done
  return 0
}

# Resolve provider binary — direct or via variant conf
provider_bin="$(_find_bin "${HARNESS_PROVIDER}")"
if [[ -z "${provider_bin}" ]]; then
  conf="$(_find_conf "${HARNESS_PROVIDER}")"
  if [[ -n "${conf}" ]]; then
    protocol="$(grep '^protocol=' "${conf}" | head -1 | cut -d= -f2-)"
    url="$(grep '^url=' "${conf}" | head -1 | cut -d= -f2-)"
    auth_env="$(grep '^auth_env=' "${conf}" | head -1 | cut -d= -f2-)"
    max_tokens="$(grep '^max_tokens=' "${conf}" | head -1 | cut -d= -f2- || true)"
    stream_conf="$(grep '^stream=' "${conf}" | head -1 | cut -d= -f2- || true)"
    provider_bin="$(_find_bin "${protocol}")"
    # Map variant config to protocol env vars
    proto_upper="$(echo "${protocol}" | tr '[:lower:]' '[:upper:]')"
    [[ -n "${url}" ]] && export "${proto_upper}_API_URL=${url}"
    [[ -n "${max_tokens}" ]] && export "${proto_upper}_MAX_TOKENS=${max_tokens}"
    key=""
    [[ -n "${auth_env}" ]] && key="${!auth_env:-}"
    if [[ -z "${key}" ]]; then
      cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
      [[ -f "${cache}" ]] && key="$(jq -r ".\"${HARNESS_PROVIDER}\"[0].key // .\"${HARNESS_PROVIDER}\"[0].token // empty" "${cache}" 2>/dev/null)" || true
    fi
    [[ -n "${key}" ]] && export "${proto_upper}_API_KEY=${key}"
  fi
fi

if [[ -z "${provider_bin}" ]]; then
  jq -n --arg msg "provider '${HARNESS_PROVIDER}' not found" '{error: $msg}'
  exit 1
fi

# Stream flag: pass --stream only when provider supports it
stream_flag=""
if [[ "${stream_conf:-}" == "always" ]] || \
   { [[ -n "${HARNESS_STREAM_FD:-}" ]] && grep -q -- '--stream' "${provider_bin}" 2>/dev/null; }; then
  stream_flag="--stream"
fi

# --- Parallel tool dispatch during streaming ---
# Tools are dispatched via a fifo as the provider streams them. A background
# dispatcher reads the fifo, executes each tool in parallel, and writes
# results to .tool_dispatch/. The tool_exec hook checks there before
# re-executing, making pre-dispatched tools instant.
_dispatch_pid=""
dispatch_dir=""

_cleanup_dispatch() {
  [[ -n "${_dispatch_pid}" ]] || return 0
  exec 4>&- 2>/dev/null || true
  wait ${_dispatch_pid} 2>/dev/null || true
  rm -f "${dispatch_dir}/.fifo" 2>/dev/null || true
  _dispatch_pid=""
}

if [[ -n "${stream_flag}" ]]; then
  dispatch_dir="${HARNESS_SESSION}/.tool_dispatch"
  rm -rf "${dispatch_dir}"
  mkdir -p "${dispatch_dir}"

  _workdir="$(sed -n 's/^cwd=//p' "${HARNESS_SESSION}/session.conf" 2>/dev/null)"
  _workdir="${_workdir:-${PWD}}"

  mkfifo "${dispatch_dir}/.fifo"

  # Background dispatcher: read tool call JSON lines, execute each in parallel
  (
    while IFS= read -r line; do
      [[ -z "${line}" ]] && continue
      _cid="$(echo "${line}" | jq -r '.id')"
      _name="$(echo "${line}" | jq -r '.name')"
      _input="$(echo "${line}" | jq -c '.input')"
      _bin="$(_find_tool "${_name}")"
      if [[ -z "${_bin}" ]]; then
        jq -n --arg r "error: tool '${_name}' not found" '{result: $r, error: true}' \
          > "${dispatch_dir}/${_cid}.json"
        continue
      fi
      (
        _r="$(cd "${_workdir}" && echo "${_input}" | "${_bin}" --exec 2>&1)" && _e=false || _e=true
        printf '%s' "${_r}" | jq -Rs --argjson e "${_e}" '{result: ., error: $e}' \
          > "${dispatch_dir}/${_cid}.json"
      ) &
    done < "${dispatch_dir}/.fifo"
    wait
  ) >/dev/null &
  _dispatch_pid=$!

  # Keep write end open so dispatcher doesn't EOF before provider starts
  exec 4>"${dispatch_dir}/.fifo"
  export HARNESS_TOOL_FIFO="${dispatch_dir}/.fifo"
fi

# Call provider, capturing stderr for error reporting
err_file="$(mktemp)"
trap 'rm -f "${err_file}"; _cleanup_dispatch' EXIT

if response="$(echo "${payload}" | "${provider_bin}" ${stream_flag} 2>"${err_file}")"; then
  _cleanup_dispatch
  cat "${err_file}" >> "${HARNESS_LOG}"
  # Fallback: display text for non-streaming providers in TTY mode
  if [[ -n "${HARNESS_STREAM_FD:-}" && -z "${stream_flag}" ]]; then
    _fb="$(echo "${response}" | jq -j '
      if .content then [.content[] | select(.type == "text") | .text] | join("")
      elif .choices then (.choices[0].message.content // "")
      else "" end' 2>/dev/null)" || true
    [[ -n "${_fb}" ]] && printf '%s' "${_fb}" >&"${HARNESS_STREAM_FD}"
  fi
  if ! echo "${response}" | jq '. + {next_state: "receive"}' 2>/dev/null; then
    echo "provider returned invalid JSON: ${response:0:200}" >&2
    jq -n --arg msg "provider returned invalid JSON" '{error: $msg}'
    exit 1
  fi
else
  rc=$?
  _cleanup_dispatch
  err="$(cat "${err_file}")"
  [[ -n "${err}" ]] && { echo "${err}" >> "${HARNESS_LOG}"; echo "${err}" >&2; }
  jq -n --arg msg "${err:-provider exited ${rc}}" '{error: $msg}'
  exit "${rc}"
fi
