#!/usr/bin/env bash
# 20-tools — discover tool plugins and assemble the tools array.
# Pipeline hook: receives partial payload on stdin, adds "tools" field.
set -euo pipefail

payload="$(cat)"

# Iterate HARNESS_SOURCES (colon-separated, lowest priority first, highest last).
# Later entries override earlier ones (same basename = higher priority wins).
IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"
declare -A tool_map
for src in "${sources[@]}"; do
  [[ -d "${src}/tools" ]] || continue
  for f in "${src}/tools"/*; do
    [[ -x "${f}" ]] || continue
    name="$(basename "${f}")"
    tool_map["${name}"]="${f}"
  done
done

# Collect schemas
tools="[]"
for name in "${!tool_map[@]}"; do
  path="${tool_map[$name]}"
  schema="$("${path}" --schema 2>/dev/null)" || continue
  tools="$(printf '%s\n%s' "${tools}" "${schema}" | jq -s '.[0] + [.[1]]')"
done

printf '%s\n%s' "${payload}" "${tools}" | jq -c -s '.[0] + {tools: .[1]}'
