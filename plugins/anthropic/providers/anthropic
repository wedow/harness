#!/usr/bin/env bash
# anthropic — provider plugin for the Anthropic Messages API.
# Receives assembled payload JSON on stdin, outputs the API response.
set -euo pipefail

[[ "${1:-}" == "--describe" ]] && { echo "Anthropic Messages API"; exit 0; }
[[ "${1:-}" == "--ready" ]] && {
  [[ -n "${ANTHROPIC_API_KEY:-}" ]] && exit 0
  cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
  [[ -f "${cache}" ]] && jq -e '.anthropic | length > 0' "${cache}" &>/dev/null
  exit $?
}
[[ "${1:-}" == "--defaults" ]] && { echo "model=claude-sonnet-4-6"; exit 0; }
[[ "${1:-}" == "--env" ]] && { cat <<'ENVEOF'
ANTHROPIC_API_KEY     API key (required)
ANTHROPIC_API_URL     API endpoint (https://api.anthropic.com/v1/messages)
ANTHROPIC_API_VERSION API version (2023-06-01)
ANTHROPIC_MAX_TOKENS  max response tokens (8192)
ENVEOF
exit 0; }

streaming=false
[[ "${1:-}" == "--stream" ]] && { streaming=true; shift; }

# Auth: support ANTHROPIC_AUTH_HEADER (for OAuth delegation) or API key
if [[ -z "${ANTHROPIC_AUTH_HEADER:-}" ]]; then
  if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
    cache="${HARNESS_HOME:-${HOME}/.harness}/.auth-cache.json"
    [[ -f "${cache}" ]] && ANTHROPIC_API_KEY="$(jq -r '.anthropic[0].key // empty' "${cache}")"
  fi
  ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:?ANTHROPIC_API_KEY not set — run: hs auth set anthropic}"
  _auth_header="x-api-key: ${ANTHROPIC_API_KEY}"
else
  _auth_header="${ANTHROPIC_AUTH_HEADER}"
fi
ANTHROPIC_API_URL="${ANTHROPIC_API_URL:-https://api.anthropic.com/v1/messages}"
ANTHROPIC_API_VERSION="${ANTHROPIC_API_VERSION:-2023-06-01}"
ANTHROPIC_MAX_TOKENS="${ANTHROPIC_MAX_TOKENS:-8192}"

_curl_headers=(
  -H "${_auth_header}"
  -H "anthropic-version: ${ANTHROPIC_API_VERSION}"
  -H "content-type: application/json"
)
[[ -n "${ANTHROPIC_BETA:-}" ]] && _curl_headers+=(-H "anthropic-beta: ${ANTHROPIC_BETA}")

payload="$(cat)"

# Extract fields from the assembled payload
model="$(echo "${payload}" | jq -r '.model // ""')"
[[ -z "${model}" ]] && model="${HARNESS_MODEL}"

system_val="$(echo "${payload}" | jq -c '.system // ""')"
messages="$(echo "${payload}" | jq -c '.messages // []')"
tools="$(echo "${payload}" | jq -c '.tools // []')"

# Build the API request body (system can be string or array of content blocks)
request="$(jq -n \
  --arg model "${model}" \
  --argjson max_tokens "${ANTHROPIC_MAX_TOKENS}" \
  --argjson system "${system_val}" \
  --argjson messages "${messages}" \
  --argjson tools "${tools}" \
  '{model: $model, max_tokens: $max_tokens, cache_control: {type: "ephemeral"},
    system: $system, messages: $messages}
   | if ($tools | length) > 0 then . + {tools: $tools} else . end'
)"

if [[ "${streaming}" == true ]]; then
  request="$(echo "${request}" | jq -c '. + {stream: true}')"

  # State for accumulating the response
  local_model=""
  input_tokens=0
  output_tokens=0
  stop_reason=""
  text_content=""
  tool_calls="[]"
  # Per-block state
  block_type=""
  block_id=""
  block_name=""
  block_input=""
  got_message_start=false

  while IFS= read -r line; do
    # Skip blank lines and event: lines
    [[ -z "${line}" || "${line}" =~ ^event: ]] && continue
    # Only process data: lines (space after colon is optional per SSE spec)
    [[ "${line}" == data:* ]] || continue
    data="${line#data:}"; data="${data# }"

    event_type="$(echo "${data}" | jq -r '.type // ""')"

    case "${event_type}" in
      message_start)
        got_message_start=true
        local_model="$(echo "${data}" | jq -r '.message.model // ""')"
        input_tokens="$(echo "${data}" | jq -r '.message.usage.input_tokens // 0')"
        ;;
      content_block_start)
        block_type="$(echo "${data}" | jq -r '.content_block.type // ""')"
        if [[ "${block_type}" == "tool_use" ]]; then
          block_id="$(echo "${data}" | jq -r '.content_block.id // ""')"
          block_name="$(echo "${data}" | jq -r '.content_block.name // ""')"
          block_input=""
        fi
        ;;
      content_block_delta)
        delta_type="$(echo "${data}" | jq -r '.delta.type // ""')"
        if [[ "${delta_type}" == "text_delta" ]]; then
          # Sentinel trick: $() strips trailing newlines; printf x preserves them
          text="$(echo "${data}" | jq -j '.delta.text // ""'; printf x)"
          text="${text%x}"
          text_content+="${text}"
          [[ -n "${HARNESS_STREAM_FD:-}" ]] && printf '%s' "${text}" >&"${HARNESS_STREAM_FD}"
        elif [[ "${delta_type}" == "input_json_delta" ]]; then
          partial="$(echo "${data}" | jq -r '.delta.partial_json // ""')"
          block_input+="${partial}"
        fi
        ;;
      content_block_stop)
        if [[ "${block_type}" == "tool_use" ]]; then
          parsed_input="$(echo "${block_input}" | jq -c '.' 2>/dev/null || echo '{}')"
          tool_calls="$(echo "${tool_calls}" | jq -c \
            --arg id "${block_id}" \
            --arg name "${block_name}" \
            --argjson input "${parsed_input}" \
            '. + [{type: "tool_use", id: $id, name: $name, input: $input}]'
          )"
          if [[ -n "${HARNESS_TOOL_FIFO:-}" ]]; then
            jq -c -n --arg id "${block_id}" --arg name "${block_name}" \
              --argjson input "${parsed_input}" \
              '{id: $id, name: $name, input: $input}' > "${HARNESS_TOOL_FIFO}"
          fi
          block_type=""
          block_id=""
          block_name=""
          block_input=""
        fi
        ;;
      message_delta)
        stop_reason="$(echo "${data}" | jq -r '.delta.stop_reason // ""')"
        output_tokens="$(echo "${data}" | jq -r '.usage.output_tokens // 0')"
        ;;
      message_stop|ping)
        ;;
    esac
  done < <(curl -sS -N "${ANTHROPIC_API_URL}" \
    "${_curl_headers[@]}" \
    -d "${request}" \
    --max-time 300
  )

  if [[ "${got_message_start}" == false ]]; then
    echo "anthropic streaming error: no message_start received" >&2
    exit 1
  fi

  # Build content array
  content="[]"
  if [[ -n "${text_content}" ]]; then
    content="$(jq -n --arg text "${text_content}" '[{type: "text", text: $text}]')"
  fi
  if [[ "$(echo "${tool_calls}" | jq 'length')" -gt 0 ]]; then
    content="$(echo "${content}" | jq -c --argjson tc "${tool_calls}" '. + $tc')"
  fi

  # Output reconstructed response
  jq -n -c \
    --arg model "${local_model}" \
    --arg stop_reason "${stop_reason}" \
    --argjson input_tokens "${input_tokens}" \
    --argjson output_tokens "${output_tokens}" \
    --argjson content "${content}" \
    '{
      model: $model,
      stop_reason: $stop_reason,
      usage: {input_tokens: $input_tokens, output_tokens: $output_tokens},
      content: $content
    }'
  exit 0
fi

# Call the API
response="$(curl -sS "${ANTHROPIC_API_URL}" \
  "${_curl_headers[@]}" \
  -d "${request}" \
  --max-time 300
)"

# Check for API errors
error_type="$(echo "${response}" | jq -r '.type // ""')"
if [[ "${error_type}" == "error" ]]; then
  error_msg="$(echo "${response}" | jq -r '.error.message // "unknown error"')"
  echo "anthropic API error: ${error_msg}" >&2
  exit 1
fi

# Pass through the raw response
echo "${response}"
