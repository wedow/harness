#!/usr/bin/env bash
# harness hooks — list discovered hooks
set -euo pipefail

case "${1:-}" in
  --describe) echo "list discovered hooks"; exit 0 ;;
esac

source "${HARNESS_ROOT}/bin/harness"

stage="${1:-}"
found=0
_refresh_sources
search_dirs=()
for src in "${_HARNESS_SOURCES[@]}"; do
  search_dirs+=("${src}/hooks.d")
done
for sd in "${search_dirs[@]}"; do
  [[ -d "${sd}" ]] || continue
  if [[ -n "${stage}" ]]; then
    [[ -d "${sd}/${stage}" ]] || continue
    for f in "${sd}/${stage}"/*; do
      [[ -x "$f" ]] && { echo "  ${stage}/$(basename "$f")  [$f]"; found=1; }
    done
  else
    for stage_dir in "${sd}"/*/; do
      [[ -d "${stage_dir}" ]] || continue
      sname="$(basename "${stage_dir}")"
      for f in "${stage_dir}"*; do
        [[ -x "$f" ]] && echo "  ${sname}/$(basename "$f")  [$f]"
      done
    done
  fi
done

if [[ -n "${stage}" && "${found}" -eq 0 ]]; then
  echo "harness: unknown stage '${stage}'" >&2
  exit 1
fi
