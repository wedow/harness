#!/usr/bin/env bash
# 10-save — parse Anthropic response, save canonical message, return control JSON.
# Receives raw Anthropic API response JSON on stdin.
set -euo pipefail

response="$(cat)"
msg_dir="${HARNESS_SESSION}/messages"
[[ -d "${msg_dir}" ]] || exit 0

# Determine next sequence number
last="$(ls -1 "${msg_dir}/" 2>/dev/null | sort -n | tail -1)"
if [[ -z "${last}" ]]; then
  seq="0001"
else
  seq="$(printf '%04d' $(( 10#${last%%-*} + 1 )))"
fi

# Extract metadata
model="$(echo "${response}" | jq -r '.model // ""')"
stop_reason="$(echo "${response}" | jq -r '.stop_reason // "end_turn"')"
input_tokens="$(echo "${response}" | jq -r '.usage.input_tokens // 0')"
output_tokens="$(echo "${response}" | jq -r '.usage.output_tokens // 0')"

# Normalize stop_reason to canonical stop field
case "${stop_reason}" in
  end_turn)   stop="end" ;;
  tool_use)   stop="tool_calls" ;;
  max_tokens) stop="length" ;;
  *)          stop="${stop_reason}" ;;
esac

# Build the markdown body from content blocks
body=""
text_output=""
tool_items="[]"
content_blocks="$(echo "${response}" | jq -c '.content[]')"

while IFS= read -r block; do
  [[ -z "${block}" ]] && continue
  btype="$(echo "${block}" | jq -r '.type')"
  case "${btype}" in
    text)
      text="$(echo "${block}" | jq -r '.text')"
      body+="${text}"$'\n'
      text_output+="${text}"
      ;;
    tool_use)
      tid="$(echo "${block}" | jq -r '.id')"
      tname="$(echo "${block}" | jq -r '.name')"
      tinput="$(echo "${block}" | jq -c '.input')"
      body+=$'\n'"\`\`\`tool_call id=${tid} name=${tname}"$'\n'
      body+="${tinput}"$'\n'
      body+='```'$'\n'
      tool_items="$(echo "${tool_items}" | jq --arg id "${tid}" --arg name "${tname}" \
        --argjson input "${tinput}" '. + [{id: $id, name: $name, input: $input}]')"
      ;;
  esac
done <<< "${content_blocks}"

# Write the canonical message file
cat > "${msg_dir}/${seq}-assistant.md" <<EOF
---
role: assistant
seq: ${seq}
timestamp: $(date -Iseconds)
model: ${model}
provider: ${HARNESS_PROVIDER}
stop: ${stop}
tokens_in: ${input_tokens}
tokens_out: ${output_tokens}
---
${body}
EOF

# Return control JSON
if [[ "${stop}" == "tool_calls" ]]; then
  echo "${tool_items}" | jq '{next_state: "tool_exec", tool_calls: .}'
else
  jq -n --arg output "${text_output}" '{next_state: "done", output: $output}'
fi
