#!/usr/bin/env bash
# 10-send — call the active provider with the assembled payload.
# On failure, outputs error JSON on stdout so the error state can display it.
set -euo pipefail

payload="$(cat)"

# Find provider binary from active sources (highest priority first = last in list)
provider_bin=""
IFS=':' read -ra sources <<< "${HARNESS_SOURCES}"
for (( i=${#sources[@]}-1; i>=0; i-- )); do
  candidate="${sources[i]}/providers/${HARNESS_PROVIDER}"
  if [[ -x "${candidate}" ]]; then
    provider_bin="${candidate}"
    break
  fi
done

if [[ -z "${provider_bin}" ]]; then
  jq -n --arg msg "provider '${HARNESS_PROVIDER}' not found" '{error: $msg}'
  exit 1
fi

# Call provider, capturing stderr for error reporting
err_file="$(mktemp)"
trap 'rm -f "${err_file}"' EXIT

if response="$(echo "${payload}" | "${provider_bin}" 2>"${err_file}")"; then
  cat "${err_file}" >> "${HARNESS_LOG}"
  echo "${response}" | jq '. + {next_state: "receive"}'
else
  rc=$?
  err="$(cat "${err_file}")"
  [[ -n "${err}" ]] && echo "${err}" >> "${HARNESS_LOG}"
  jq -n --arg msg "${err:-provider exited ${rc}}" '{error: $msg}'
  exit "${rc}"
fi
