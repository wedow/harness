#!/usr/bin/env bash
# skill — tool plugin: load a skill's full instructions and list its resources.
set -euo pipefail

case "${1:-}" in
  --schema)
    cat <<'JSON'
{
  "name": "skill",
  "description": "Load a skill's full instructions. Call this when a task matches an available skill's description.",
  "input_schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "The skill name from the available-skills catalog"
      }
    },
    "required": ["name"]
  }
}
JSON
    ;;
  --describe)
    echo "Load a skill's instructions by name"
    ;;
  --exec)
    input="$(cat)"
    skill_name="$(echo "${input}" | jq -r '.name')"

    # Walk CWD upward collecting skill search dirs (most-local first)
    search_dirs=()
    cur="${HARNESS_CWD:-${PWD}}"
    while true; do
      [[ -d "${cur}/.harness/skills" ]] && search_dirs+=("${cur}/.harness/skills")
      [[ -d "${cur}/.agents/skills" ]]  && search_dirs+=("${cur}/.agents/skills")
      [[ "${cur}" == "/" ]] && break
      cur="$(dirname "${cur}")"
    done
    # Ensure ~ is included
    home_found=0
    for d in "${search_dirs[@]}"; do
      [[ "${d}" == "${HOME}/.harness/skills" || "${d}" == "${HOME}/.agents/skills" ]] && home_found=1
    done
    if (( ! home_found )); then
      [[ -d "${HOME}/.harness/skills" ]] && search_dirs+=("${HOME}/.harness/skills")
      [[ -d "${HOME}/.agents/skills" ]]  && search_dirs+=("${HOME}/.agents/skills")
    fi

    # Bundled plugin skills (lowest priority — appended last so local wins).
    # Iterates HARNESS_SOURCES for skills/ in plugin source dirs; skips .harness/
    # dirs (already covered by the walk above).
    IFS=':' read -ra _src_arr <<< "${HARNESS_SOURCES:-}"
    for _src in "${_src_arr[@]}"; do
      case "${_src}" in */.harness) continue ;; esac
      [[ "${_src}" == "${HOME}/.harness" ]] && continue
      [[ -d "${_src}/skills" ]] && search_dirs+=("${_src}/skills")
    done

    # Find skill: match by SKILL.md frontmatter `name:` (the same identifier
    # the catalog publishes in <available-skills>). Directory name is irrelevant
    # for resolution — a skill at skills/anything/SKILL.md with `name: foo` is
    # loadable as `foo`. Most-local wins = first match.
    skillmd=""
    for sdir in "${search_dirs[@]}"; do
      for candidate_dir in "${sdir}"/*/; do
        candidate_md="${candidate_dir}SKILL.md"
        [[ -f "${candidate_md}" ]] || continue
        fm_name="$(awk '/^---$/{n++; next} n==1 && /^name:[[:space:]]*/{sub(/^name:[[:space:]]*/, ""); print; exit}' "${candidate_md}")"
        if [[ "${fm_name}" == "${skill_name}" ]]; then
          skillmd="${candidate_md}"
          break 2
        fi
      done
    done

    if [[ -z "${skillmd}" ]]; then
      echo "error: skill '${skill_name}' not found"
      exit 1
    fi

    skill_dir="$(dirname "${skillmd}")"

    # Extract body (everything after the closing --- of frontmatter)
    body="$(awk '/^---$/{n++; next} n>=2{print}' "${skillmd}")"

    # List bundled resources (scripts/, references/, assets/)
    resources=""
    for subdir in scripts references assets; do
      if [[ -d "${skill_dir}/${subdir}" ]]; then
        while IFS= read -r f; do
          [[ -n "${f}" ]] && resources+="  ${subdir}/${f}"$'\n'
        done < <(ls -1 "${skill_dir}/${subdir}" 2>/dev/null)
      fi
    done

    # Output with structured wrapping
    echo "<skill name=\"${skill_name}\">"
    echo "${body}"
    echo ""
    echo "Skill directory: ${skill_dir}"
    echo "Relative paths in this skill resolve against the skill directory."
    if [[ -n "${resources}" ]]; then
      echo ""
      echo "<skill-resources>"
      printf '%s' "${resources}"
      echo "</skill-resources>"
    fi
    echo "</skill>"
    ;;
  *)
    echo "usage: skill --schema | --describe | --exec" >&2
    exit 1
    ;;
esac
